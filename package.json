    "smoke:cpg-translation-google-provider": "python3 projects/crewportglobal/scripts/smoke_translation_google_provider.py",
    "build:cpg-i18n-runtime-bundle": "python3 projects/crewportglobal/scripts/build_translation_runtime_bundle.py",
    "check:cpg-i18n-runtime-bundle": "python3 projects/crewportglobal/scripts/check_translation_runtime_bundle.py",
