# GTSTOR split contour (example)
PROJECT_NAME=gtstor
PROJECT_MODE=compat

# DB (GTSTOR chat tables: chat*)
PGHOST=127.0.0.1
PGPORT=5432
PGDATABASE=gtc_db
PGUSER=gtc_user
PGPASSWORD=gtc_pass

# API/web entrypoints (compat mode)
GTSTOR_WEB_ENTRY=/index.html
GTSTOR_CHAT_ENTRY=/chat/
GTSTOR_API_ENTRY=/chat_api.php
