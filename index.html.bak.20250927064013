<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>GTC Unified Access</title>
  <style>
    :root{
      --bg:#0a0d1e;--card:#111933;--muted:#2b2b2b;--fg:#fff;--primary:#2962ff;--primary-2:#0039cb;--ok:#8bc34a;--info:#29b6f6;--err:#ff5252;
    }
    *{box-sizing:border-box}
    body{
      margin:0;padding:0;background:var(--bg);color:var(--fg);
      font-family:system-ui,-apple-system,"Segoe UI",Roboto,Ubuntu,"Helvetica Neue",Arial,"Noto Sans",sans-serif;
      min-height:100vh;display:grid;place-items:center
    }
    .wrap{
      width:min(480px,92vw);background:var(--card);padding:24px 22px;border-radius:16px;
      box-shadow:0 0 24px rgba(0,102,255,.28)
    }
    .logo{display:block;width:80px;margin:0 auto 14px auto}
    h1{margin:.25rem 0 1rem 0;font-size:1.4rem;text-align:center}
    label{display:block;margin-top:12px;font-size:.95rem}
    input,select,button{
      width:100%;padding:11px 12px;border:none;border-radius:8px;outline:none
    }
    input,select{background:var(--muted);color:var(--fg)}
    button{margin-top:16px;background:var(--primary);color:#fff;font-weight:600;cursor:pointer;transition:.2s}
    button:hover{background:var(--primary-2)}
    .row{display:grid;gap:10px}
    .muted{opacity:.9;font-size:.9rem}
    .hint{font-size:.85rem;margin-top:6px}
    .ok{color:var(--ok)} .info{color:var(--info)} .err{color:var(--err)}
    .hidden{display:none}
    .actions{display:flex;gap:10px;margin-top:10px}
    .actions a{
      flex:1;text-align:center;display:inline-block;padding:10px 12px;border-radius:8px;background:#1b2344;color:#fff;text-decoration:none
    }
    .center{text-align:center}
  </style>
  <link rel="icon" href="/favicon.ico" sizes="any">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
  <link rel="manifest" href="/site.webmanifest">
</head>
<body>
  <main class="wrap">
    <img class="logo" src="https://kfilipenko.github.io/gtc-form/assets/logo.png" alt="GTC Logo"/>
    <h1>Welcome to GTC</h1>

    <div id="already" class="hidden center">
      <p class="ok">You are recognized as <span id="uid"></span>.</p>
      <div class="actions">
        <a id="toNews" href="#">Go to the latest news</a>
      </div>
    </div>

    <form id="form">
      <div class="row">
        <!-- Google Sign-In button -->
        <div id="g_id_onload" data-client_id="REPLACE_WITH_GOOGLE_CLIENT_ID" data-login_uri="" data-auto_prompt="false" class="hidden"></div>
        <div class="center" style="margin-bottom:8px">
          <div id="gSignIn"></div>
        </div>

        <label for="mode">Action</label>
        <select id="mode" name="mode" required>
          <option value="login" selected>Login</option>
          <option value="register">Register</option>
        </select>

        <label for="email">Email address</label>
        <input id="email" name="email" type="email" autocomplete="email" required/>

        <div id="nameBox" class="hidden">
          <label for="name">Name (for registration)</label>
          <input id="name" name="name" type="text" autocomplete="name"/>
        </div>

        <label for="password">Password</label>
        <input id="password" name="password" type="password" required autocomplete="new-password"/>
        <div id="pwHint" class="hint info"></div>

        <label for="source">Source</label>
        <select id="source" name="source" required>
          <option value="web" selected>Website</option>
          <option value="telegram">Telegram</option>
          <option value="github">GitHub Page</option>
          <option value="wix">Wix</option>
          <option value="tilda">Tilda</option>
          <option value="other">Other</option>
        </select>

        <button type="submit" id="submitBtn">Continue</button>
        <div id="note" class="hint"></div>
      </div>
    </form>
  </main>

  <script>
    // CONFIG: replace with your n8n webhook endpoint and Google client id
    //   const N8N_WEBHOOK = '/webhooks/user-register'; // proxy or absolute URL to n8n
    // New: use local server registration endpoint instead of n8n
    const REGISTER_ENDPOINT = '/register'; // POST JSON -> { email, name, password, source, channel, action }
    const GOOGLE_CLIENT_ID = 'REPLACE_WITH_GOOGLE_CLIENT_ID';

    // load Google Identity Services script dynamically
    (function loadGoogle(){
      const s = document.createElement('script');
      s.src = 'https://accounts.google.com/gsi/client';
      s.defer = true;
      s.onload = initGoogle;
      document.head.appendChild(s);
    })();

    function initGoogle(){
      if(!window.google || !google.accounts) return;
      // Render a Google Sign-In button that will return a credential (JWT)
      google.accounts.id.initialize({
        client_id: GOOGLE_CLIENT_ID,
        callback: handleGoogleCredentialResponse,
      });
      google.accounts.id.renderButton(
        document.getElementById('gSignIn'),
        { theme: 'outline', size: 'large', width: '280' }
      );
      // do not auto prompt
      // google.accounts.id.prompt();
      // show button only if client id configured
      if(GOOGLE_CLIENT_ID && GOOGLE_CLIENT_ID.indexOf('REPLACE')===-1){
        document.getElementById('gSignIn').style.display = 'block';
      }
    }

    async function handleGoogleCredentialResponse(resp){
      // resp.credential is a JWT token identifying the user
      if(!resp || !resp.credential) return;
      note.textContent = '';
      try{
        const payload = { google_token: resp.credential, channel: 'google', action: 'register' };
        const res = await fetch(N8N_WEBHOOK, {
          method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(payload)
        });
        const json = await res.json();
        if(json && json.gtc_user_id){
          localStorage.setItem('gtc_user_id', String(json.gtc_user_id));
          localStorage.setItem('email', json.email || '');
          // redirect to latest news
          const newsId = await getLatestNewsId();
          if(newsId) location.href = `/news/?news_id=${encodeURIComponent(newsId)}`;
          else { note.textContent = 'Registered via Google. No news yet.'; note.className='hint info'; }
        }else{
          throw new Error('No gtc_user_id returned');
        }
      }catch(err){
        console.error(err);
        note.textContent = 'Google registration failed. Please try email sign-up.'; note.className='hint err';
      }
    }

    const qs = s => document.querySelector(s);
    const modeEl = qs('#mode');
    const nameBox = qs('#nameBox');
    const pw = qs('#password');
    const pwHint = qs('#pwHint');
    const form = qs('#form');
    const note = qs('#note');
    const already = qs('#already');
    const uidSpan = qs('#uid');
    const toNews = qs('#toNews');

    // If user already known -> quick path to news
    (function bootstrap(){
      try{
        const gu = localStorage.getItem('gtc_user_id');
        if(gu){
          uidSpan.textContent = displayUid(+gu);
          already.classList.remove('hidden');
          toNews.addEventListener('click', async (e)=>{
            e.preventDefault();
            const id = await getLatestNewsId();
            if(id) location.href = `/news/?news_id=${encodeURIComponent(id)}`;
          });
        }
      }catch(e){}
    })();

    modeEl.addEventListener('change', () => {
      const reg = modeEl.value === 'register';
      nameBox.classList.toggle('hidden', !reg);
    });

    pw.addEventListener('input', () => {
      const ok = /^(?=.*[a-zA-Z])(?=.*\d)(?=.*[^a-zA-Z0-9]).{8,}$/.test(pw.value);
      pwHint.textContent = ok ? 'Password strength: Good' : '8+ chars, letters, numbers & special char required.';
      pwHint.className = 'hint ' + (ok ? 'ok' : 'info');
    });

    form.addEventListener('submit', async (e)=>{
      e.preventDefault();
      note.textContent = '';
      const ok = /^(?=.*[a-zA-Z])(?=.*\d)(?=.*[^a-zA-Z0-9]).{8,}$/.test(pw.value);
      if(!ok){ note.textContent = 'Please improve password.'; note.className='hint err'; return; }

      const payload = {
        mode: qs('#mode').value,
        email: qs('#email').value.trim().toLowerCase(),
        name:  qs('#name')?.value?.trim() || null,
        password: qs('#password').value,
        source: qs('#source').value,
        channel: 'web',
        action: qs('#mode').value
      };

      try{
        // Call our backend registration endpoint which returns created user (with gtc_user_id)
        const res = await fetch(REGISTER_ENDPOINT, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify(payload)
        });
        if(!res.ok) throw new Error(`Registration failed: ${res.status}`);
        const json = await res.json();
        // Expect { id, gtc_user_id, email }
        localStorage.setItem('user_id', String(json.id));
        localStorage.setItem('gtc_user_id', String(json.gtc_user_id));
        localStorage.setItem('email', json.email || payload.email);
        const newsId = await getLatestNewsId();
        if(newsId) {
          location.href = `/news/?news_id=${encodeURIComponent(newsId)}`;
        } else {
          note.textContent = 'Registered. No news found yet.';
          note.className = 'hint info';
        }
      }catch(err){
        console.error(err);
        note.textContent = 'Request failed. Please try again.';
        note.className = 'hint err';
      }
    });

    async function getLatestNewsId(){
      const r = await fetch('/api/v_news_web?select=news_id&locale=eq.en&order=created_at_web.desc&limit=1');
      const arr = await r.json();
      return Array.is
