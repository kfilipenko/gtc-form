 .field-note,\n    .feature-list li,\n    .hero-aside p,\n    .status-note {\n      margin: 0;\n      color: var(--muted-on-dark);\n      line-height: 1.65;\n    }\n\n    .actions,\n    .mini-actions,\n    .field-actions {\n      display: flex;\n      flex-wrap: wrap;\n      gap: 12px;\n    }\n\n    .hero-aside {\n      display: grid;\n      gap: 16px;\n    }\n\n    .hero-aside section,\n    .vacancy-card,\n    .value-card,\n    .trust-card,\n    .cta-card,\n    .search-field {\n      padding: 20px;\n      border-radius: 20px;\n      background: rgba(255, 255, 255, 0.04);\n      border: 1px solid var(--line);\n    }\n\n    .hero-aside h2,\n    .section-title,\n    .vacancy-card h3,\n    .value-card h3,\n    .trust-card h3,\n    .cta-card h3 {\n      margin: 0 0 10px;\n      font-size: 24px;\n      letter-spacing: -0.03em;\n      color: var(--paper-strong);\n    }\n\n    .search-grid {\n      grid-template-columns: repeat(3, minmax(0, 1fr));\n    }\n\n    .search-field {\n      display: grid;\n      gap: 10px;\n    }\n\n    .search-field strong,\n    .value-card strong,\n    .trust-card strong,\n    .vacancy-card strong,\n    .cta-card strong {\n      color: var(--paper-strong);\n    }\n\n    .search-field select,\n    .search-field input {\n      width: 100%;\n      padding: 14px 16px;\n      border-radius: 16px;\n      border: 1px solid var(--line);\n      background: rgba(255, 255, 255, 0.06);\n      color: var(--text-on-dark);\n      font: inherit;\n    }\n\n    .search-field input::placeholder {\n      color: var(--muted-on-dark);\n    }\n\n    .vacancy-grid,\n    .value-grid,\n    .trust-grid,\n    .cta-grid {\n      grid-template-columns: repeat(3, minmax(0, 1fr));\n    }\n\n    .vacancy-card {\n      display: grid;\n      gap: 16px;\n      min-height: 100%;\n    }\n\n    .vacancy-meta {\n      display: grid;\n      grid-template-columns: repeat(2, minmax(0, 1fr));\n      gap: 12px;\n    }\n\n    .vacancy-meta span,\n    .vacancy-status {\n      color: var(--muted-on-dark);\n      font-size: 14px;\n      line-height: 1.5;\n    }\n\n    .vacancy-status {\n      display: inline-flex;\n      align-items: center;\n      justify-content: center;\n      width: fit-content;\n      min-height: 34px;\n      padding: 8px 12px;\n      border-radius: 999px;\n      border: 1px solid rgba(255, 139, 61, 0.28);\n      background: rgba(255, 139, 61, 0.08);\n    }\n\n    .feature-list {\n      margin: 0;\n      padding-left: 18px;\n      display: grid;\n      gap: 10px;\n    }\n\n    .cta-card {\n      display: grid;\n      gap: 14px;\n    }\n\n    @media (max-width: 980px) {\n      .home-grid,\n      .search-grid,\n      .vacancy-grid,\n      .value-grid,\n      .trust-grid,\n      .cta-grid,\n      .vacancy-meta {\n        grid-template-columns: 1fr;\n      }\n    }\n  "],"\n  ",["LINK",{"rel":"stylesheet","href":"assets/crewportglobal-app.css"}],"\n"],"\n",["BODY",{"class":"doc-body cpg-app-page"},"\n  ",["DIV",{"class":"site-shell"},"\n    ",["HEADER",{"class":"site-header"},"\n      ",["A",{"class":"brand","href":"https://crewportglobal.com/"},"\n        ",["SPAN",{"class":"brand-mark"},"CPG"],"\n        ",["SPAN",{"class":"brand-copy"},"\n          ",["STRONG",{},"CrewPortGlobal"],"\n          ",["SPAN",{"data-i18n":"site.tagline"},"Морская платформа вакансий и экипажей"],"\n        "],"\n      "],"\n      ",["DIV",{"id":"language-selector","class":"language-selector"},"\n        ",["BUTTON",{"id":"current-language-toggle","class":"language-toggle","type":"button","aria-expanded":"false","aria-controls":"header-language-menu","aria-label":"Russian language selector"},"\n          ",["SPAN",{"class":"language-toggle__flag","id":"current-language-flag","aria-hidden":"true"},"🇷🇺"],"\n          ",["SPAN",{"class":"language-toggle__copy"},"\n            ",["SPAN",{"class":"language-toggle__hint","data-i18n":"site.languageLabel"},"Язык"],"\n            ",["SPAN",{"class":"language-toggle__label","id":"current-language-label"},"Русский"],"