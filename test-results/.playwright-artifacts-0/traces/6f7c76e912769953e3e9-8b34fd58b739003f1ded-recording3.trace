          ",["P",{},"CrewPortGlobal takes complaints seriously and aims to provide a clear, fair and documented review process."],"\n",["H2",{},"You may submit a complaint about"],"\n",["H2",{},"Recommended complaint information"],"\n",["OL",{},"\n",["LI",{},"Full name and contact details."],"\n",["LI",{},"Role: seafarer, shipowner, partner or other."],"\n",["LI",{},"GTC_USER_ID, if available."],"\n",["LI",{},"Vessel, company or partner details, if relevant."],"\n",["LI",{},"Description of the issue."],"\n",["LI",{},"Date of the event."],"\n",["LI",{},"Screenshots, files or other evidence."],"\n",["LI",{},"Desired outcome."],"\n"],"\n",["H2",{},"Contact channel"],"\n",["P",{},"Recommended public complaint channels:"],"\n",["PRE",{},["CODE",{"class":"language-text"},"complaints@crewportglobal.com\nsupport@crewportglobal.com\n"]],"\n",["P",{},"Temporary contact until dedicated mailboxes are active:"],"\n",["PRE",{},["CODE",{"class":"language-text"},"kfilipenko@gtchain.io\n"]],"\n",["H2",{},"Priority treatment"],"\n",["P",{},"Complaints about recruitment, placement or employment-related fees are treated as high priority or critical priority."],"\n",["P",{},"CrewPortGlobal does not charge seafarers recruitment, placement or employment fees."],"\n",["H2",{},"Review process summary"],"\n",["OL",{},"\n",["LI",{},"Complaint is registered."],"\n",["LI",{},"Acknowledgement is sent."],"\n",["LI",{},"Evidence is reviewed."],"\n",["LI",{},"Interim protective measures may be taken where needed."],"\n",["LI",{},"Outcome is recorded and communicated."],"\n"],"\n",["P",{},"The full internal procedure is maintained in the CrewPortGlobal complaint handling document."],"\n          \n        "],"\n\n        ",["ASIDE",{"class":"doc-sidebar"},"\n          ",["SECTION",{"class":"card sidebar-panel"},"\n                        ",["P",{"class":"eyebrow","data-i18n":"doc.publicationSet"},"Пакет публикации"],"\n                        ",["H2",{"data-i18n":"doc.clientFacingLibrary"},"Публичная библиотека"],"\n                        ",["P",{"data-i18n":"doc.libraryBody"},"Все публичные документы CrewPortGlobal используют единую навигацию, структуру маршрутов и визуальный стиль."],"\n          "],"\n\n          \n\n          ",["SECTION",{"class":"card library-grid"},"\n            ",["A",{"class":"library-link","href":"https://crewportglobal.com/about/"},"\n  ",["SPAN",{"class":"library-type"},"Positioning"],"\n  ",["STRONG",{},"Project Scope"],"\n  ",["SPAN",{},"Defines what CrewPortGlobal is, what it is not, and how the Stage 1 commercial model is framed."],"\n"],"\n",["A",{"class":"library-link","href":"https://crewportglobal.com/how-it-works/"},"\n  ",["SPAN",{"class":"library-type"},"Overview"],"\n  ",["STRONG",{},"How It Works"],"\n  ",["SPAN",{},"Explains the practical action-first workflow for seafarers, employers and human-reviewed maritime hiring support."],"\n"],"\n",["A",{"class":"library-link","href":"https://crewportglobal.com/for-shipowners/"},"\n  ",["SPAN",{"class":"library-type"},"Audience"],"\n  ",["STRONG",{},"For Employers"],"\n  ",["SPAN",{},"Present your company clearly, prepare vacancy requests and review candidate profiles through a controlled maritime hiring workflow."],"\n"],"\n",["A",{"class":"library-link","href":"https://crewportglobal.com/for-seafarers/"},"\n  ",["SPAN",{"class":"library-type"},"Audience"],"\n  ",["STRONG",{},"For Seafarers"],"\n  ",["SPAN",{},"Present your maritime experience clearly, keep documents organised and stay ready for reviewed vacancies without recruitment fees."],"\n"],"\n",["A",{"class":"library-link","href":"https://crewportglobal.com/legal/no-recruitment-fees/"},"\n  ",["SPAN",{"class":"library-type"},"Policy"],"\n  ",["STRONG",{},"No Recruitment Fees"],"\n  ",["SPAN",{},"Core trust rule: seafarers must not be charged recruitment, placement or employment-access fees."],"\n"],"\n",["A",{"class":"library-link","href":"https://crewportglobal.com/legal/privacy/"},"\n  ",["SPAN",{"class":"library