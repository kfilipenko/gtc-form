bel"},"видимость CV"],"\n            "],"\n            ",["DIV",{"class":"app-stat"},"\n              ",["STRONG",{"data-i18n":"home.stat.fees.value"},"0"],"\n              ",["SPAN",{"data-i18n":"home.stat.fees.label"},"рекрутинговых сборов с моряка"],"\n            "],"\n            ",["DIV",{"class":"app-stat"},"\n              ",["STRONG",{"data-i18n":"home.stat.review.value"},"Ручная"],"\n              ",["SPAN",{"data-i18n":"home.stat.review.label"},"проверка"],"\n            "],"\n          "],"\n          ",["P",{"class":"trust-note app-chip good","data-i18n":"home.hero.trust"},"CrewPortGlobal не взимает с моряков сборы за трудоустройство или размещение. Профили и запросы на вакансии проходят ручную проверку до более широкой публикации или представления кандидата."],"\n        "],"\n\n        ",["ASIDE",{"class":"hero-aside app-hero-media"},"\n          ",["IMG",{"__playwright_current_src__":"http://127.0.0.1:38123/assets/maritime-operations.jpg","src":"assets/maritime-operations.jpg","alt":"Container ship unloading at port"}],"\n          ",["SECTION",{"class":"app-panel"},"\n            ",["P",{"class":"eyebrow","data-i18n":"home.seafarers.eyebrow"},"Для моряков"],"\n            ",["H2",{"data-i18n":"home.seafarers.title"},"Соберите морское CV и профиль документов"],"\n            ",["P",{"data-i18n":"home.seafarers.copy"},"Добавьте должность, сертификаты, доступность, контакты и метаданные документов в одном месте до отклика."],"\n          "],"\n          ",["SECTION",{"class":"app-panel"},"\n            ",["P",{"class":"eyebrow","data-i18n":"home.employers.eyebrow"},"Для работодателей"],"\n            ",["H2",{"data-i18n":"home.employers.title"},"Подготовьте запрос на вакансию с понятными деталями"],"\n            ",["P",{"data-i18n":"home.employers.copy"},"Укажите компанию, судно, должность, зарплату, дату посадки, длительность контракта и требования до публикации."],"\n          "],"\n          ",["SECTION",{"class":"app-panel"},"\n            ",["P",{"class":"eyebrow","data-i18n":"home.boundary.eyebrow"},"Правила доверия"],"\n            ",["H2",{"data-i18n":"home.boundary.title"},"Публичные вакансии появляются только при готовности реальных данных"],"\n            ",["P",{"data-i18n":"home.boundary.copy"},"CrewPortGlobal не обещает автоматическое трудоустройство или автоматическое одобрение. Публичные вакансии появляются только тогда, когда проверенные данные готовы к публикации."],"\n          "],"\n        "],"\n      "],"\n\n      ",["SECTION",{"class":"card vacancy-search section-card app-search-card"},"\n        ",["P",{"class":"eyebrow","data-i18n":"home.search.eyebrow"},"Быстрый поиск вакансий"],"\n        ",["H2",{"class":"section-title","data-i18n":"home.search.title"},"Начните с должности, типа судна и сроков."],"\n        ",["P",{"class":"section-copy","data-i18n":"home.search.copy"},"Используйте должность, тип судна и сроки, чтобы увидеть, как будет устроен поиск после появления публичных вакансий."],"\n        ",["DIV",{"class":"search-grid app-search-grid","id":"vacancy-search-block"},"\n          ",["LABEL",{"class":"search-field"},"\n            ",["STRONG",{"data-i18n":"home.search.position"},"Должность"],"\n            ",["SELECT",{},"\n              ",["OPTION",{"__playwright_selected_":"true","data-i18n":"home.search.position.option1"},"Капитан / Старпом / Палубная команда"],"\n              ",["OPTION",{"__playwright_selected_":"false","data-i18n":"home.search.position.option2"},"Старший механик / Машинная команда"],"\n              ",["OPTION",{"__playwright_selected_":"false","data-i18n":"home.search.position.option3"},"Повар / Стюард / Отельная команда"],"\n            "],"\n          "],"\n          ",["LABEL",{"class":"search-field"},"\n            ",["STRONG",{"data-i18n":"home.search.vessel"},"Тип судна"],"\n            ",["SELECT",{},"\n              ",["OPTION",{"__playwright_selected_":"true","data-i18n":"home.search.vessel.option1"},"Балкер / Танкер / Контейнеровоз"],"\n        