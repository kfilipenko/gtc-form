{"type":"frame-snapshot","snapshot":{"callId":"call@78","snapshotName":"after@call@78","pageId":"page@17e00bb73c3bb069fa7c88f297a31115","frameId":"frame@9866446cd82980a2f6c50c7013b925f1","frameUrl":"http://127.0.0.1:38123/index.html","doctype":"html","html":["HTML",{"lang":"ru","dir":"ltr","translate":"yes"},["HEAD",{},["BASE",{"href":"http://127.0.0.1:38123/index.html"}],"\n  ",["META",{"charset":"utf-8"}],"\n  ",["META",{"name":"viewport","content":"width=device-width, initial-scale=1"}],"\n  ",["TITLE",{},"CrewPortGlobal | Maritime jobs and crew platform"],"\n  ",["META",{"id":"page-description","name":"description","content":"Practical entry point for seafarer profiles, employer vacancy intake and human-reviewed maritime hiring workflows."}],"\n  ",["LINK",{"rel":"icon","type":"image/png","sizes":"32x32","href":"/favicon-32x32.png"}],"\n  ",["LINK",{"rel":"icon","type":"image/png","sizes":"16x16","href":"/favicon-16x16.png"}],"\n  ",["LINK",{"rel":"apple-touch-icon","sizes":"180x180","href":"/apple-touch-icon.png"}],"\n  ",["LINK",{"rel":"shortcut icon","href":"/favicon.ico"}],"\n  ",["LINK",{"rel":"stylesheet","href":"assets/crewportglobal-docs.css"}],"\n  ",["STYLE",{},"\n    .home-grid,\n    .search-grid,\n    .vacancy-grid,\n    .value-grid,\n    .trust-grid,\n    .cta-grid {\n      display: grid;\n      gap: 18px;\n    }\n\n    .home-grid {\n      grid-template-columns: minmax(0, 1.2fr) minmax(340px, 0.8fr);\n      align-items: start;\n    }\n\n    .hero-copy,\n    .hero-aside,\n    .vacancy-search,\n    .vacancy-board,\n    .value-panel,\n    .trust-panel,\n    .cta-panel {\n      padding: 28px;\n    }\n\n    .hero-copy {\n      display: grid;\n      gap: 20px;\n    }\n\n    .landing-title {\n      margin: 0;\n      font-size: clamp(42px, 7vw, 72px);\n      line-height: 0.94;\n      letter-spacing: -0.05em;\n      max-width: 11ch;\n      color: var(--paper-strong);\n    }\n\n    .landing-lead,\n    .section-copy,\n    .support-copy,\n    .empty-state,\n    .field-note,\n    .feature-list li,\n    .hero-aside p,\n    .status-note {\n      margin: 0;\n      color: var(--muted-on-dark);\n      line-height: 1.65;\n    }\n\n    .actions,\n    .mini-actions,\n    .field-actions {\n      display: flex;\n      flex-wrap: wrap;\n      gap: 12px;\n    }\n\n    .hero-aside {\n      display: grid;\n      gap: 16px;\n    }\n\n    .hero-aside section,\n    .vacancy-card,\n    .value-card,\n    .trust-card,\n    .cta-card,\n    .search-field {\n      padding: 20px;\n      border-radius: 20px;\n      background: rgba(255, 255, 255, 0.04);\n      border: 1px solid var(--line);\n    }\n\n    .hero-aside h2,\n    .section-title,\n    .vacancy-card h3,\n    .value-card h3,\n    .trust-card h3,\n    .cta-card h3 {\n      margin: 0 0 10px;\n      font-size: 24px;\n      letter-spacing: -0.03em;\n      color: var(--paper-strong);\n    }\n\n    .search-grid {\n      grid-template-columns: repeat(3, minmax(0, 1fr));\n    }\n\n    .search-field {\n      display: grid;\n      gap: 10px;\n    }\n\n    .search-field strong,\n    .value-card strong,\n    .trust-card strong,\n    .vacancy-card strong,\n    .cta-card strong {\n      color: var(--paper-strong);\n    }\n\n    .search-field select,\n    .search-field input {\n      width: 100%;\n      padding: 14px 16px;\n      border-radius: 16px;\n      border: 1px solid var(--line);\n      background: rgba(255, 255, 255, 0.06);\n      color: var(--text-on-dark);\n      font: inherit;\n    }\n\n    .search-field input::placeholder {\n      color: var(--muted-on-dark);\n    }\n\n    .vacancy-grid,\n    .value-grid,\n    .trust-grid,\n    .cta-grid {\n      grid-template-columns: repeat(3, minmax(0, 1fr));\n    }\n\n    .vacancy-card {\n      display: grid;\n      gap: 16px;\n      min-height: 100%;\n    }\n\n    .vacancy-meta {\n      display: grid;\n      grid-template-columns: repeat(2, minmax(0, 1fr));\n      gap: 12px;\n    }\n\n    .vacancy-meta span,\n    .vacancy-status {\n      color: var(--muted-on-dark);\n      font-size: 14px;\n      line-height: 1.5;\n    }\n\n    .vacancy-status {\n      display: inline-flex;\n      align-items: center;\n      justify-content: center;\n      width: fit-content;\n      min-height: 34px;\n      padding: 8px 12px;\n      border-radius: 999px;\n      border: 1px solid rgba(255, 139, 61, 0.28);\n      background: rgba(255, 139, 61, 0.08);\n    }\n\n    .feature-list {\n      margin: 0;\n      padding-left: 18px;\n      display: grid;\n      gap: 10px;\n    }\n\n    .cta-card {\n      display: grid;\n      gap: 14px;\n    }\n\n    @media (max-width: 980px) {\n      .home-grid,\n      .search-grid,\n      .vacancy-grid,\n      .value-grid,\n      .trust-grid,\n      .cta-grid,\n      .vacancy-meta {\n        grid-template-columns: 1fr;\n      }\n    }\n  "],"\n  ",["LINK",{"rel":"stylesheet","href":"assets/crewportglobal-app.css"}],"\n"],"\n",["BODY",{"class":"doc-body cpg-app-page"},"\n  ",["DIV",{"class":"site-shell"},"\n    ",["HEADER",{"class":"site-header"},"\n      ",["A",{"class":"brand","href":"https://crewportglobal.com/"},"\n        ",["SPAN",{"class":"brand-mark"},"CPG"],"\n        ",["SPAN",{"class":"brand-copy"},"\n          ",["STRONG",{},"CrewPortGlobal"],"\n          ",["SPAN",{"data-i18n":"site.tagline"},"Морская платформа вакансий и экипажей"],"\n        "],"\n      "],"\n      ",["DIV",{"id":"language-selector","class":"language-selector"},"\n        ",["BUTTON",{"id":"current-language-toggle","class":"language-toggle","type":"button","aria-expanded":"false","aria-controls":"header-language-menu","aria-label":"Russian language selector"},"\n          ",["SPAN",{"class":"language-toggle__flag","id":"current-language-flag","aria-hidden":"true"},"🇷🇺"],"\n          ",["SPAN",{"class":"language-toggle__copy"},"\n            ",["SPAN",{"class":"language-toggle__hint","data-i18n":"site.languageLabel"},"Язык"],"\n            ",["SPAN",{"class":"language-toggle__label","id":"current-language-label"},"Русский"],"