ку вакансий"],"\n            "],"\n          "],"\n        "],"\n      "],"\n\n      ",["SECTION",{"class":"card vacancy-board section-card"},"\n        ",["P",{"class":"eyebrow","data-i18n":"home.board.eyebrow"},"Последние вакансии"],"\n        ",["H2",{"class":"section-title","data-i18n":"home.board.title"},"Текущая публичная доска вакансий"],"\n        ",["P",{"class":"section-copy","data-i18n":"home.board.copy"},"Публичных вакансий пока нет. Работодатели уже могут подготовить запрос на вакансию, а живая публикация остаётся ограниченной реальными проверенными данными."],"\n        ",["DIV",{"class":"vacancy-grid"},"\n          ",["ARTICLE",{"class":"vacancy-card"},"\n            ",["DIV",{},"\n              ",["P",{"class":"eyebrow","data-i18n":"home.board.card1.eyebrow"},"Публичная доступность"],"\n              ",["H3",{"data-i18n":"home.board.card1.title"},"Публичных вакансий пока нет"],"\n            "],"\n            ",["P",{"class":"empty-state","data-i18n":"home.board.card1.copy"},"Когда проверенные вакансии будут готовы, здесь появятся должность, тип судна, зарплата, дата посадки, длительность контракта и данные работодателя."],"\n            ",["SPAN",{"class":"vacancy-status","data-i18n":"home.board.card1.status"},"Текущий превью-режим"],"\n            ",["DIV",{"class":"mini-actions"},"\n              ",["A",{"class":"button secondary","href":"https://crewportglobal.com/vacancies/","data-i18n":"home.board.card1.cta"},"Открыть доску вакансий"],"\n            "],"\n          "],"\n          ",["ARTICLE",{"class":"vacancy-card"},"\n            ",["DIV",{},"\n              ",["P",{"class":"eyebrow","data-i18n":"home.board.card2.eyebrow"},"Следующий шаг работодателя"],"\n              ",["H3",{"data-i18n":"home.board.card2.title"},"Подготовьте запрос на вакансию"],"\n            "],"\n            ",["P",{"class":"empty-state","data-i18n":"home.board.card2.copy"},"Используйте поля компании, судна, должности, зарплаты, даты посадки и длительности контракта, чтобы подготовить будущий формат публикации."],"\n            ",["SPAN",{"class":"vacancy-status","data-i18n":"home.board.card2.status"},"Запрос от компании"],"\n            ",["DIV",{"class":"mini-actions"},"\n              ",["A",{"class":"button secondary","href":"https://crewportglobal.com/post-vacancy/","data-i18n":"home.board.card2.cta"},"Подготовить запрос на вакансию"],"\n            "],"\n          "],"\n          ",["ARTICLE",{"class":"vacancy-card"},"\n            ",["DIV",{},"\n              ",["P",{"class":"eyebrow","data-i18n":"home.board.card3.eyebrow"},"Следующий шаг моряка"],"\n              ",["H3",{"data-i18n":"home.board.card3.title"},"Подготовьте профиль до открытия вакансий"],"\n            "],"\n            ",["P",{"class":"empty-state","data-i18n":"home.board.card3.copy"},"Держите CV, доступность, сертификаты и контакты готовыми, чтобы откликнуться, когда появятся живые вакансии."],"\n            ",["SPAN",{"class":"vacancy-status","data-i18n":"home.board.card3.status"},"Путь готовности профиля"],"\n            ",["DIV",{"class":"mini-actions"},"\n              ",["A",{"class":"button secondary","href":"https://crewportglobal.com/create-profile/","data-i18n":"home.board.card3.cta"},"Создать профиль моряка"],"\n            "],"\n          "],"\n        "],"\n      "],"\n\n      ",["SECTION",{"class":"value-grid"},"\n        ",["ARTICLE",{"class":"card value-panel value-card"},"\n          ",["P",{"class":"eyebrow","data-i18n":"home.value.employers.eyebrow"},"Для работодателей"],"\n          ",["H3",{"data-i18n":"home.value.employers.title"},"Перейдите от потребности в экипаже к структурированному запросу на вакансию."],"\n          ",["UL",{"class":"feature-list"},"\n            ",["LI",{"data-i18n":"home.value.employers.item1"},"Покажите данные компании и контекст работодателя понятно."],"\n            ",["LI",{"data-i18n":"home.value.employers.item2"},"Укажите должность, тип судна, зарплату, дату посадки и длительность."],"\n            ",["LI",{"data-i18n":"home.value.employers.item3"},"Передавайте требования до более широкой публикации."],"\n            ",["LI",{"data-i18n":"home.value.employers.item4"},"Просматривайте подготовленные профили моряков после ручной проверки."],"\n            ",["LI",{"data-i18n":"home.value.employers.item5"},"Сохраняйте коммуникацию контролируемой и профессиональной."],"\n            ",["LI",{"data-i18n":"home.value.employers.item6"},"Используйте проверку и правила доверия до живой публикации."],"\n          "],"\n          ",["DIV",{"class":"mini-actions"},"\n            ",["A",{"class":"button primary","href":"https://crewportglobal.com/post-vacancy/","data-i18n":"home.value.employers.cta"},"Подготовить запрос на вакансию"],"\n          "],"\n        "],"\n        ",["ARTICLE",{"class":"card value-panel value-card"},"\n          ",["P",{"class":"eyebrow","data-i18n":"home.value.seafarers.eyebrow"},"Для моряков"],"\n          ",["H3",{"data-i18n":"home.value.seafarers.title"},"Соберите профиль, готовый к серьёзному рассмотрению."],"\n          ",["UL",{"class":"feature-list"},"\n            ",["LI",{"data-i18n":"home.value.seafarers.item1"},"Создайте онлайн-CV с должностью, доступностью и базовыми контактами."],"\n            ",["LI",{"data-i18n":"home.value.seafarers.item2"},"Добавьте сертификаты и метаданные документов в одном месте."],"\n            ",["LI",{"data-i18n":"home.value.seafarers.item3"},"Держите полноту профиля и подтверждения на виду."],"\n            ",["LI",{"data-i18n":"home.value.seafarers.item4"},"Отправьте профиль на ручную проверку."],"\n            ",["LI",{"data-i18n":"home.value.seafarers.item5"},"Подготовьтесь до появления публичных вакансий."],"\n            ",["LI",{"data-i18n":"home.value.seafarers.item6"},"Сохраняйте правило без рекрутинговых сборов видимым с самого начала."],"\n          "],"\n          ",["DIV",{"class":"mini-actions"},"\n            ",["A",{"class":"button primary","href":"https://crewportglobal.com/create-profile/","data-i18n":"home.value.seafarers.cta"},"Создать профиль моряка"],"\n          "],"\n        "],"\n        ",["ARTICLE",{"class":"card value-panel value-card"},"\n          ",["P",{"class":"eyebrow","data-i18n":"home.value.workflow.eyebrow"},"Как работает платформа"],"\n          ",["H3",{"data-i18n":"home.value.workflow.title"},"Сначала полезные действия, правила доверия всегда на виду."],"\n          ",["UL",{"class":"feature-list"},"\n            ",["LI",{"data-i18n":"home.value.workflow.item1"},"Сразу создайте профиль, подготовьте запрос на вакансию или откройте доску вакансий."],"\n            ",["LI",{"data-i18n":"home.value.workflow.item2"},"Держите правила доверия, проверки и отсутствия сборов внутри каждого шага."],"\n            ",["LI",{"data-i18n":"home.value.workflow.item3"},"Не обещайте автоматическое одобрение, автоматический подбор или автоматическое трудоустройство."],"\n            ",["LI",{"data-i18n":"home.value.workflow.item4"},"Используйте ручную проверку там, где важны готовность и представление кандидата."],"\n          "],"\n          ",["DIV",{"class":"mini-actions"},"\n            ",["A",{"class":"button secondary","href":"https://crewportglobal.com/how-it-works/","data-i18n":"home.value.workflow.cta"},"Посмотреть процесс"],"\n          "],"\n        "],"\n      "],"\n\n      ",["SECTION",{"class":"trust-grid"},"\n        ",["ARTICLE",{"class":"card trust-panel trust-card"},"\n          ",["P",{"class":"eyebrow"},"Trust & Safety"],"\n          ",["H3",{"data-i18n":"home.trust.fees.title"},"Обещание без рекрутинговых сборов остаётся явным."],"\n          ",["P",{"class":"support-copy","data-i18n":"home.trust.fees.copy"},"Моряки не платят за рекрутинг, трудоустройство или доступ к подаче профиля через CrewPortGlobal."],"\n        "],"\n        ",["ARTICLE",{"class":"card trust-panel trust-card"},"\n          ",["P",{"class":"eyebrow","data-i18n":"home.trust.review.eyebrow"},"Ручная проверка"],"\n          ",["H3",{"data-i18n":"home.trust.review.title"},"Одобрение не происходит автоматически."],"\n          ",["P",{"class":"support-copy","data-i18n":"home.trust.review.copy"},"Профили и запросы на вакансии отправляются на ручную проверку до более широкой публикации или представления кандидатов."],"\n        "],"\n        ",["ARTICLE",{"class":"card trust-panel trust-card"},"\n          ",["P",{"class":"eyebrow","data-i18n":"home.trust.live.eyebrow"},"Живая публикация"],"\n          ",["H3",{"data-i18n":"home.trust.live.title"},"Публичные вакансии появляются только при готовности реальных данных."],"\n          ",["P",{"class":"support-copy","data-i18n":"home.trust.live.copy"},"CrewPortGlobal публикует живые вакансии только тогда, когда есть проверенные данные работодателя и вакансия готова к публичному показу."],"\n        "],"\n      "],"\n\n      ",["SECTION",{"class":"cta-grid"},"\n        ",["ARTICLE",{"class":"card cta-panel cta-card"},"\n          ",["P",{"class":"eyebrow","data-i18n":"home.cta.seafarer.eyebrow"},"Следующий шаг моряка"],"\n          ",["H3",{"data-i18n":"home.cta.seafarer.title"},"Создайте профиль моряка"],"\n          ",["P",{"class":"status-note","data-i18n":"home.cta.seafarer.copy"},"Начните с базового профиля, сертификатов, доступности и контактов, затем отправьте профиль на ручную проверку."],"\n          ",["A",{"class":"button primary","href":"https://crewportglobal.com/create-profile/","data-i18n":"home.cta.seafarer.button"},"Создать профиль моряка"],"\n        "],"\n        ",["ARTICLE",{"class":"card cta-panel cta-card"},"\n          ",["P",{"class":"eyebrow","data-i18n":"home.cta.employer.eyebrow"},"Следующий шаг работодателя"],"\n          ",["H3",{"data-i18n":"home.cta.employer.title"},"Подготовьте запрос на вакансию"],"\n          ",["P",{"class":"status-note","data-i18n":"home.cta.employer.copy"},"Добавьте компанию, судно, должность, зарплату, дату посадки, длительность контракта и ключевые требования до публикации."],"\n          ",["A",{"class":"button primary","href