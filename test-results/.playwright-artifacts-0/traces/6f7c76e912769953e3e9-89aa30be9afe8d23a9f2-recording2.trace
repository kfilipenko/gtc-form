ewportglobal.com/legal/shipowner-service-terms/","data-i18n":"nav.shipownerAgreement"},"Соглашение судовладельца"],"\n      ",["A",{"class":"nav-link","href":"https://crewportglobal.com/legal/recruitment-and-matching-policy/","data-i18n":"nav.matchingPolicy"},"Политика matching"],"\n      ",["A",{"class":"nav-link","href":"https://crewportglobal.com/legal/verification-policy/","data-i18n":"nav.verificationPolicy"},"Политика verification"],"\n      ",["A",{"class":"nav-link","href":"https://crewportglobal.com/legal/complaints/","data-i18n":"nav.complaints"},"Жалобы"],"\n    "],"\n\n    ",["MAIN",{"class":"doc-main"},"\n      ",["SECTION",{"class":"landing-hero"},"\n        ",["ARTICLE",{"class":"card hero-copy"},"\n          ",["P",{"class":"eyebrow","data-i18n":"home.stage"},"Этап 1"],"\n          ",["H1",{"class":"landing-title","data-i18n":"home.title"},"Морские кадровые процессы с комплаенсом в основе."],"\n          ",["P",{"class":"landing-lead","data-i18n":"home.lead"},"CrewPortGlobal развивается как цифровая платформа для морских данных экипажей, документов и matching workflows для судовладельцев, операторов и моряков. Публичная клиентская документация публикуется в Markdown как канонический формат, а онбординг моряков начинается через отдельный acceptance-first route."],"\n          ",["DIV",{"class":"actions"},"\n            ",["A",{"class":"button primary","href":"https://crewportglobal.com/for-shipowners/","data-i18n":"nav.forShipowners"},"Для судовладельцев"],"\n            ",["A",{"class":"button secondary","href":"https://crewportglobal.com/for-seafarers/","data-i18n":"nav.forSeafarers"},"Для моряков"],"\n            ",["A",{"class":"button secondary","href":"https://crewportglobal.com/onboarding/seafarer-registration/","data-i18n":"home.startOnboarding"},"Начать онбординг моряка"],"\n            ",["A",{"class":"button secondary","href":"https://crewportglobal.com/legal/verification-policy/","data-i18n":"nav.verificationPolicy"},"Политика verification"],"\n            ",["A",{"class":"button secondary","href":"https://crewportglobal.com/how-it-works/","data-i18n":"nav.howItWorks"},"Как это работает"],"\n            ",["A",{"class":"button secondary","href":"https://crewportglobal.com/about/","data-i18n":"nav.projectScope"},"О проекте"],"\n          "],"\n          ",["P",{"class":"trust-note","data-i18n":"home.trustNote"},"CrewPortGlobal не взимает с моряков рекрутинговые или placement fees."],"\n        "],"\n\n        ",["ASIDE",{"class":"card hero-panel"},"\n          ",["SECTION",{},"\n            ",["P",{"class":"eyebrow","data-i18n":"nav.forShipowners"},"Для судовладельцев"],"\n            ",["H2",{"data-i18n":"home.shipownersTitle"},"Структурированный intake и проверенные shortlists"],"\n            ",["P",{"data-i18n":"home.shipownersBody"},"Собирайте crew requests, оценивайте readiness кандидатов и переходите к shortlist preparation через документированные compliance checkpoints."],"\n          "],"\n          ",["SECTION",{},"\n            ",["P",{"class":"eyebrow","data-i18n":"nav.forSeafarers"},"Для моряков"],"\n            ",["H2",{"data-i18n":"home.seafarersTitle"},"Профессиональный профиль и готовность документов"],"\n            ",["P",{"data-i18n":"home.seafarersBody"},"Начните с acceptance onboarding, подготовьте базовые морские документы и оставайтесь внутри no-fee access model."],"\n          "],"\n          ",["SECTION",{},"\n            ",["P",{"class":"eyebrow","data-i18n":"home.governanceLabel"},"Управление"],"\n            ",["H2",{"data-i18n":"home.governanceTitle"},"AI assistance с human review"],"\n            ",["P",{"data-i18n":"home.governanceBody"},"Автоматизация может помогать intake и matching support, но финальная подача кандидата требует human review."],"\n          "],"\n        "],"\n      "],"\n\n      ",["SECTION",{"class":"card verification-band"},"\n        ",["DIV",{"class":"docs-head"},"\n          ",["DIV",{},"\n            ",["P",{"class":"eyebrow","data-i18n":"home.verificationLabel"},"Verification"],"\n            ",["H2",{"data-i18n":"home.verificationTitle"},"Проверка по обеим сторонам кадрового процесса"],"\n          "],"\n          ",["P",{"data-i18n":"home.verificationBody"},"Проверки identity, business и vessel рассматриваются как единая verification surface, а не как разрозненные trust notes."],"\n        "],"\n\n        ",["DIV",{"class":"verification-grid"},"\n          ",["A",{"class":"verification-card","href":"https://crewportglobal.com/legal/verification-policy/"},"\n            ",["SPAN",{"class":"doc-type","data-i18n":"home.verificationSeafarersType"},"Моряки"],"\n            ",["STRONG",{"data-i18n":"home.verificationSeafarersTitle"},"Identity моряка и профессиональная готовность"],"\n            ",["SPAN",{"class":"doc-note","data-i18n":"home.verificationSeafarersBody"},"Identity, сертификаты, полнота документов и профессиональная readiness проверяются до серьёзной matching activity."],"\n          "],"\n          ",["A",{"class":"verification-card","href":"https://crewportglobal.com/legal/verification-policy/"},"\n            ",["SPAN",{"class":"doc-type","data-i18n":"home.verificationBusinessType"},"Бизнес"],"\n            ",["STRONG",{"data-i18n":"home.verificationBusinessTitle"},"KYB бизнес-клиента"],"\n            ",["SPAN",{"class":"doc-note","data-i18n":"home.verificationBusinessBody"},"Проверка legal entity, authority представителя, санкционного контекста и legitimacy onboarding для business clients."],"\n          "],"\n          ",["A",{"class":"verification-card","href":"https://crewportglobal.com/legal/verification-policy/"},"\n            ",["SPAN",{"class":"doc-type","data-i18n":"home.verificationVesselsType"},"Суда"],"\n            ",["STRONG",{"data-i18n":"home.verificationVesselsTitle"},"Проверка судна"],"\n            ",["SPAN",{"class":"doc-note","data-i18n":"home.verificationVesselsBody"},"Проверяются identity судна, ownership или management context, flag и operational legitimacy там, где