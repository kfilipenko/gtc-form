bout/","data-i18n":"nav.projectScope"},"Escopo do projeto"],[[6,193]]],[[6,195]],["P",{"class":"trust-note","data-i18n":"home.trustNote"},"A CrewPortGlobal não cobra taxas de recrutamento ou colocação dos marítimos."],[[6,198]]],[[6,200]],["ASIDE",{"class":"card hero-panel"},[[6,201]],["SECTION",{},[[6,202]],["P",{"class":"eyebrow","data-i18n":"nav.forShipowners"},"Para armadores"],[[6,205]],["H2",{"data-i18n":"home.shipownersTitle"},"Intake estruturado e shortlists verificados"],[[6,208]],["P",{"data-i18n":"home.shipownersBody"},"Colete solicitações de tripulação, revise a prontidão dos candidatos e avance para a preparação de shortlist com checkpoints documentados de compliance."],[[6,211]]],[[6,213]],["SECTION",{},[[6,214]],["P",{"class":"eyebrow","data-i18n":"nav.forSeafarers"},"Para marítimos"],[[6,217]],["H2",{"data-i18n":"home.seafarersTitle"},"Perfil profissional e prontidão documental"],[[6,220]],["P",{"data-i18n":"home.seafarersBody"},"Comece pela aceitação do onboarding, prepare os documentos marítimos principais e permaneça dentro de um modelo sem taxas."],[[6,223]]],[[6,225]],["SECTION",{},[[6,226]],["P",{"class":"eyebrow","data-i18n":"home.governanceLabel"},"Governança"],[[6,229]],["H2",{"data-i18n":"home.governanceTitle"},"Assistência de IA com revisão humana"],[[6,232]],["P",{"data-i18n":"home.governanceBody"},"A automação pode ajudar no intake e no suporte ao matching, mas a submissão final do candidato exige revisão humana."],[[6,235]]],[[6,237]]],[[6,239]]],[[6,241]],["SECTION",{"class":"card verification-band"},[[6,242]],["DIV",{"class":"docs-head"},[[6,243]],["DIV",{},[[6,244]],["P",{"class":"eyebrow","data-i18n":"home.verificationLabel"},"Verificação"],[[6,247]],["H2",{"data-i18n":"home.verificationTitle"},"Verificado dos dois lados do fluxo de tripulação"],[[6,250]]],[[6,252]],["P",{"data-i18n":"home.verificationBody"},"As verificações de identidade, negócio e embarcação são tratadas como uma superfície operacional única de verificação."],[[6,