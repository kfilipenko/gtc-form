profile-sidebar,\n    .profile-form,\n    .step-card {\n      align-content: start;\n    }\n\n    .profile-hero-card {\n      display: grid;\n      gap: 18px;\n    }\n\n    .profile-title {\n      margin: 0;\n      max-width: 18ch;\n      color: var(--app-ink);\n      font-size: clamp(36px, 5vw, 58px);\n      line-height: 1.02;\n      letter-spacing: 0;\n    }\n\n    .lead-copy,\n    .status-note,\n    .profile-status-panel p,\n    .profile-sidebar p,\n    .step-card p,\n    .step-card li,\n    .field-note {\n      color: var(--app-muted);\n      line-height: 1.6;\n    }\n\n    .inline-actions,\n    .section-actions,\n    .section-save-row,\n    .section-tabs {\n      display: flex;\n      flex-wrap: wrap;\n      gap: 10px;\n      align-items: center;\n    }\n\n    .readiness-grid,\n    .summary-grid {\n      grid-template-columns: repeat(4, minmax(0, 1fr));\n    }\n\n    .summary-grid {\n      grid-template-columns: repeat(2, minmax(0, 1fr));\n    }\n\n    .readiness-card,\n    .summary-card {\n      display: grid;\n      gap: 6px;\n      min-height: 84px;\n      padding: 14px;\n      border: 1px solid var(--app-line);\n      background: var(--app-surface-2);\n      border-radius: 8px;\n    }\n\n    .readiness-card strong,\n    .summary-card strong {\n      color: var(--app-ink);\n      font-size: clamp(20px, 2vw, 28px);\n      line-height: 1;\n    }\n\n    .readiness-card span,\n    .summary-card span {\n      color: var(--app-muted);\n      font-size: 13px;\n      line-height: 1.35;\n    }\n\n    .application-history {\n      gap: 16px;\n    }\n\n    .application-history__status {\n      color: var(--app-muted);\n      line-height: 1.55;\n    }\n\n    .application-list {\n      display: grid;\n      gap: 10px;\n    }\n\n    .application-item {\n      display: grid;\n      gap: 10px;\n      padding: 14px;\n      border: 1px solid var(--app-line);\n      border-radius: 8px;\n      background: var(--app-surface-2);\n    }\n\n    .application-item__head {\n      display: flex;\n      flex-wrap: wrap;\n      gap: 8px 12px;\n      align-items: baseline;\n      justify-content: space-between;\n    }\n\n    .application-item h3,\n    .application-item p {\n      margin: 0;\n    }\n\n    .application-item h3 {\n      min-width: 0;\n      color: var(--app-ink);\n      font-size: 18px;\n      line-height: 1.25;\n      letter-spacing: 0;\n      overflow-wrap: anywhere;\n    }\n\n    .application-item__status {\n      padding: 5px 8px;\n      border: 1px solid var(--app-line);\n      border-radius: 999px;\n      background: #fff;\n      color: var(--app-ocean-dark);\n      font-size: 12px;\n      font-weight: 700;\n    }\n\n    .application-item__meta {\n      display: flex;\n      flex-wrap: wrap;\n      gap: 8px;\n      color: var(--app-muted);\n      font-size: 13px;\n      line-height: 1.45;\n    }\n\n    .application-item__meta span {\n      padding: 6px 8px;\n      border: 1px solid var(--app-line);\n      border-radius: 999px;\n      background: #fff;\n    }\n\n    .application-item__note {\n      color: var(--app-muted);\n      line-height: 1.55;\n    }\n\n    .application-action {\n      min-height: 36px;\n      padding: 8px 10px;\n      border-radius: 8px;\n      font-size: 13px;\n    }\n\n    .document-upload-panel {\n      display: grid;\n      gap: 14px;\n      padding: 16px;\n      border: 1px solid var(--app-line);\n      border-radius: 8px;\n      background: var(--app-surface-2);\n    }\n\n    .document-upload-grid {\n      display: grid;\n      grid-template-columns: minmax(180px, 0.38fr) minmax(220px, 1fr) auto;\n      gap: 10px;\n      align-items: end;\n    }\n\n    .document-upload-list {\n      display: grid;\n      gap: 10px;\n    }\n\n    .document-action-list {\n      display: grid;\n      gap: 10px;\n    }\n\n    .document-action-task {\n      display: grid;\n      gap: 10px;\n      padding: 14px;\n      border: 1px solid #d9992c;\n      border-radius: 8px;\n      background: #fff8e8;\n    }\n\n    .document-action-task strong {\n      color: var(--app-ink);\n      overflow-wrap: anywhere;\n    }\n\n    .document-action-task p {\n      margin: 0;\n      color: var(--app-muted);\n      line-height: 1.5;\n    }\n\n    .document-action-task__meta {\n      display: grid;\n      gap: 4px;\n    }\n\n    .document-action-task__actions {\n      display: flex;\n      flex-wrap: wrap;\n      gap: 8px;\n      align-items: center;\n    }\n\n    .document-upload-item {\n      display: grid;\n      gap: 8px;\n      padding: 12px;\n      border: 1px solid var(--app-line);\n      border-radius: 8px;\n      background: #fff;\n    }\n\n    .document-upload-item strong {\n      color: var(--app-ink);\n      overflow-wrap: anywhere;\n    }\n\n    .document-upload-meta {\n      display: flex;\n      flex-wrap: wrap;\n      gap: 8px;\n      color: var(--app-muted);\n      font-size: 13px;\n      line-height: 1.45;\n    }\n\n    .document-upload-meta span {\n      padding: 5px 8px;\n      border: 1px solid var(--app-line);\n      border-radius: 999px;\n      background: var(--app-surface-2);\n    }\n\n    .profile-status-panel {\n      display: grid;\n      gap: 14px;\n    }\n\n    .status-row {\n      display: grid;\n      gap: 8px;\n      padding-bottom: 14px;\n      border-bottom: 1px solid var(--app-line);\n    }\n\n    .status-row:last-child {\n      padding-bottom: 0;\n      border-bottom: 0;\n    }\n\n    .profile-workspace {\n      grid-template-columns: minmax(230px, 0.28fr) minmax(0, 1fr);\n      align-items: start;\n    }\n\n    .profile-sidebar {\n      position: sticky;\n      top: 14px;\n      display: grid;\n      gap: 16px;\n    }\n\n    .section-tabs {\n      display: grid;\n      gap: 8px;\n    }\n\n    .section-tab {\n      justify-content: flex-start;\n      width: 100%;\n      border-color: var(--app-line);\n      background: #fff;\n      color: var(--app-ocean-dark);\n    }\n\n    .section-tab.is-current {\n      border-color: var(--app-ocean);\n      background: #eaf5f6;\n      color: var(--app-ocean-dark);\n    }\n\n    .missing-list {\n      display: grid;\n      gap: 7px;\n      margin: 0;\n      padding-left: 18px;\n      color: var(--app-muted);\n      line-height: 1.5;\n    }\n\n    .profile-form {\n      display: grid;\n      gap: 22px;\n    }\n\n    .form-section {\n      display: grid;\n      gap: 14px;\n      padding-top: 4px;\n    }\n\n    .form-section + .form-section {\n      padding-top: 22px;\n      border-top: 1px solid var(--app-line);\n    }\n\n    .profile-card-section {\n      padding: 0;\n      border: 1px solid var(--app-line);\n      border-radius: 8px;\n      background: var(--app-surface-2);\n    }\n\n    .profile-card-section + .profile-card-section,\n    .form-section + .profile-card-section,\n    .profile-card-section + .form-section {\n      padding-top: 0;\n      border-top: 1px solid var(--app-line);\n    }\n\n    .profile-card-section summary {\n      display: flex;\n      align-items: center;\n      justify-content: space-between;\n      gap: 12px;\n      min-height: 54px;\n      padding: 14px 16px;\n      color: var(--app-ink);\n      font-weight: 800;\n      cursor: pointer;\n      list-style: none;\n    }\n\n    .profile-card-section summary::-webkit-details-marker {\n      display: none;\n    }\n\n    .profile-card-section summary::after {\n      content: \"+\";\n      display: grid;\n      place-items: center;\n      width: 28px;\n      height: 28px;\n      border: 1px solid var(--app-line);\n      border-radius: 999px;\n      color: var(--app-ocean-dark);\n      background: #fff;\n      font-weight: 800;\n      flex: 0 0 auto;\n    }\n\n    .profile-card-section[open] summary {\n      border-bottom: 1px solid var(--app-line);\n    }\n\n    .profile-card-section[open] summary::after {\n      content: \"-\";\n    }\n\n    .profile-card-section__body {\n      display: grid;\n      gap: 14px;\n      padding: 16px;\n    }\n\n    .section-save-row {\n      justify-content: space-between;\n      padding-top: 2px;\n    }\n\n    .section-save-status {\n      margin: 0;\n      min-height: 22px;\n      font-size: 14px;\n    }\n\n    .section-heading {\n      display: grid;\n      gap: 6px;\n    }\n\n    .section-heading h2 {\n      margin: 0;\n      color: var(--app-ink);\n      font-size: 24px;\n      line-height: 1.2;\n      letter-spacing: 0;\n    }\n\n    .section-heading p {\n      margin: 0;\n    }\n\n    .field-grid {\n      grid-template-columns: repeat(2, minmax(0, 1fr));\n    }\n\n    .field-card {\n      display: grid;\n      gap: 8px;\n      padding: 0;\n      border: 0;\n      background: transparent;\n    }\n\n    .field-card.full {\n      grid-column: 1 / -1;\n    }\n\n    .field-card input,\n    .field-card select,\n    .field-card textarea {\n      width: 100%;\n      min-height: 44px;\n      padding: 11px 12px;\n      border: 1px solid var(--app-line);\n      background: #fff;\n      color: var(--app-ink);\n      border-radius: 8px;\n      font: inherit;\n    }\n\n    .field-card textarea {\n      min-height: 104px;\n      resize: vertical;\n    }\n\n    .field-card strong {\n      color: var(--app-ink);\n      font-size: 13px;\n    }\n\n    .form-footer {\n      display: grid;\n      gap: 10px;\n      padding-top: 18px;\n      border-top: 1px solid var(--app-line);\n    }\n\n    .step-grid {\n      grid-template-columns: repeat(3, minmax(0, 1fr));\n    }\n\n    .step-card {\n      display: grid;\n      gap: 10px;\n    }\n\n    .step-card ul {\n      display: grid;\n      gap: 8px;\n      margin: 0;\n      padding-left: 18px;\n    }\n\n    @media (max-width: 1040px) {\n      .profile-hero,\n      .profile-workspace,\n      .step-grid,\n      .readiness-grid {\n        grid-template-columns: 1fr;\n      }\n\n      .profile-sidebar {\n        position: static;\n      }\n\n      .section-tabs {\n        grid-template-columns: repeat(4, minmax(0, 1fr));\n      }\n    }\n\n    @media (max-width: 720px) {\n      .profile-hero-card,\n      .profile-statu