weight: 600;\n    }\n\n    .language-hero {\n      display: grid;\n      gap: 20px;\n      padding: 32px;\n    }\n\n    .language-summary {\n      display: grid;\n      gap: 8px;\n      padding: 20px;\n      border-radius: 20px;\n      background: rgba(255, 255, 255, 0.04);\n      border: 1px solid var(--line);\n    }\n\n    .language-summary p,\n    .language-summary h2,\n    .language-note p,\n    .language-note h2 {\n      margin: 0;\n    }\n\n    .language-grid {\n      display: grid;\n      grid-template-columns: repeat(2, minmax(0, 1fr));\n      gap: 16px;\n    }\n\n    .language-card {\n      width: 100%;\n      display: grid;\n      grid-template-columns: auto minmax(0, 1fr) auto;\n      align-items: center;\n      gap: 14px;\n      padding: 18px;\n      border: 1px solid var(--line);\n      border-radius: 22px;\n      background: rgba(255, 255, 255, 0.04);\n      color: var(--paper-strong);\n      text-align: left;\n      cursor: pointer;\n    }\n\n    .language-card.is-current {\n      background: rgba(113, 175, 240, 0.12);\n      border-color: rgba(113, 175, 240, 0.38);\n    }\n\n    .language-card__copy strong {\n      font-size: 17px;\n    }\n\n    .language-card__copy span {\n      color: var(--muted-on-dark);\n      font-size: 13px;\n    }\n\n    .language-card__status {\n      display: inline-flex;\n      align-items: center;\n      justify-content: center;\n      min-width: 80px;\n      padding: 8px 10px;\n      border-radius: 999px;\n      background: rgba(255, 255, 255, 0.08);\n      color: var(--paper-strong);\n      font-size: 12px;\n      font-weight: 600;\n    }\n\n    .language-notes {\n      display: grid;\n      grid-template-columns: repeat(2, minmax(0, 1fr));\n      gap: 20px;\n    }\n\n    .language-note {\n      padding: 24px;\n    }\n\n    .language-actions {\n      display: flex;\n      justify-content: flex-start;\n    }\n\n    .language-back {\n      display: inline-flex;\n      align-items: center;\n      justify-content: center;\n