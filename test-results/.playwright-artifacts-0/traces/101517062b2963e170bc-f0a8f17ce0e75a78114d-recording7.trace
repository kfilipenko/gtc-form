{"type":"frame-snapshot","snapshot":{"callId":"call@217","snapshotName":"after@call@217","pageId":"page@4dadbeedf069cb2264f3c4c509f1609b","frameId":"frame@76efa37ef5b0cb3d8d7b2d860b48a877","frameUrl":"http://127.0.0.1:38123/cabinet/?draft_id=9e354f95-d281-4304-9a10-1682da0985f5","doctype":"html","html":["HTML",{"lang":"en","data-cpg-theme-mode":"dark","data-cpg-theme":"dark","dir":"ltr","translate":"yes","style":"color-scheme: dark;"},["HEAD",{},["BASE",{"href":"http://127.0.0.1:38123/cabinet/?draft_id=9e354f95-d281-4304-9a10-1682da0985f5"}],"\n  ",["META",{"charset":"utf-8"}],"\n  ",["META",{"name":"viewport","content":"width=device-width, initial-scale=1"}],"\n  ",["TITLE",{},"CrewPortGlobal | Personal cabinet"],"\n  ",["META",{"name":"robots","content":"noindex,nofollow"}],"\n  ",["LINK",{"rel":"canonical","href":"https://crewportglobal.com/cabinet/"}],"\n  ",["LINK",{"rel":"icon","type":"image/png","sizes":"32x32","href":"/favicon-32x32.png"}],"\n  ",["LINK",{"rel":"icon","type":"image/png","sizes":"16x16","href":"/favicon-16x16.png"}],"\n  ",["LINK",{"rel":"apple-touch-icon","sizes":"180x180","href":"/apple-touch-icon.png"}],"\n  ",["LINK",{"rel":"shortcut icon","href":"/favicon.ico"}],"\n  ",["LINK",{"rel":"stylesheet","href":"../assets/crewportglobal-docs.css"}],"\n  ",["LINK",{"rel":"stylesheet","href":"../assets/crewportglobal-app.css"}],"\n  ",["STYLE",{},"\n    :root {\n      --cabinet-bg: #eef4f7;\n      --cabinet-surface: #ffffff;\n      --cabinet-soft: #f6fafc;\n      --cabinet-ink: #102a43;\n      --cabinet-muted: #526b7a;\n      --cabinet-line: #c8d6df;\n      --cabinet-line-strong: #90a8b6;\n      --cabinet-primary: #087a8c;\n      --cabinet-primary-dark: #045b69;\n      --cabinet-warning-bg: #fff8e8;\n      --cabinet-warning-line: #d9992c;\n      --cabinet-danger: #b42318;\n      --cabinet-success: #087443;\n    }\n\n    html[data-cpg-theme=\"dark\"] {\n      --cabinet-bg: #07111c;\n      --cabinet-surface: rgba(19, 38, 58, 0.92);\n      --cabinet-soft: rgba(12, 27, 43, 0.9);\n      --cabinet-ink: #e8f0f7;\n      --cabinet-muted: #9fb4c8;\n      --cabinet-line: rgba(137, 164, 190, 0.26);\n      --cabinet-line-strong: rgba(137, 164, 190, 0.4);\n      --cabinet-primary: #54c9d9;\n      --cabinet-primary-dark: #8fe4ef;\n      --cabinet-warning-bg: rgba(255, 210, 138, 0.12);\n      --cabinet-warning-line: rgba(255, 210, 138, 0.62);\n      --cabinet-danger: #ff9b91;\n      --cabinet-success: #79e2a6;\n    }\n\n    * { box-sizing: border-box; }\n\n    body {\n      min-height: 100vh;\n      margin: 0;\n      background: var(--cabinet-bg);\n      color: var(--cabinet-ink);\n      font-family: Inter, system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif;\n    }\n\n    html[data-cpg-theme=\"dark\"] body {\n      background:\n        radial-gradient(circle at 10% 0%, rgba(255, 139, 61, 0.12), transparent 26%),\n        radial-gradient(circle at 90% 10%, rgba(84, 201, 217, 0.12), transparent 24%),\n        var(--cabinet-bg);\n    }\n\n    .cabinet-shell {\n      width: min(1180px, calc(100% - 28px));\n      margin: 0 auto;\n      padding: 16px 0 40px;\n      display: grid;\n      gap: 12px;\n    }\n\n    .cabinet-header,\n    .cabinet-status,\n    .cabinet-card,\n    .task-item,\n    .document-item,\n    .service-item {\n      border: 1px solid var(--cabinet-line);\n      background: var(--cabinet-surface);\n      box-shadow: 0 10px 30px rgba(16, 42, 67, 0.08);\n    }\n\n    .cabinet-header {\n      display: flex;\n      align-items: center;\n      justify-content: space-between;\n      gap: 16px;\n      min-height: 60px;\n      padding: 12px 14px;\n      border-radius: 8px;\n    }\n\n    .cabinet-brand {\n      display: flex;\n      align-items: center;\n      gap: 12px;\n      min-width: 0;\n      color: var(--cabinet-ink);\n      text-decoration: none;\n    }\n\n    .cabinet-brand-mark {\n      width: 42px;\n      height: 42px;\n      display: grid;\n      place-items: center;\n      flex: 0 0 auto;\n      border-radius: 8px;\n      background: var(--cabinet-primary);\n      color: #fff;\n      font-weight: 900;\n    }\n\n    .cabinet-brand-copy {\n      display: grid;\n      gap: 3px;\n    }\n\n    .cabinet-brand-copy span,\n    .muted {\n      color: var(--cabinet-muted);\n      line-height: 1.5;\n    }\n\n    .header-actions {\n      display: flex;\n      flex-wrap: wrap;\n      gap: 8px;\n      justify-content: flex-end;\n      align-items: center;\n    }\n\n    h1,\n    h2,\n    h3,\n    p {\n      margin-top: 0;\n    }\n\n    h1 {\n      margin-bottom: 6px;\n      font-size: clamp(28px, 4vw, 42px);\n      line-height: 1.08;\n      letter-spacing: 0;\n    }\n\n    .cabinet-lede {\n      max-width: 780px;\n      margin-bottom: 0;\n      color: var(--cabinet-muted);\n      font-size: 16px;\n      line-height: 1.55;\n    }\n\n    .cabinet-status {\n      display: grid;\n      grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));\n      gap: 8px;\n      padding: 10px;\n      border-radius: 8px;\n    }\n\n    .status-tile {\n      display: grid;\n      gap: 5px;\n      min-height: 66px;\n      padding: 10px;\n      border: 1px solid var(--cabinet-line);\n      border-radius: 8px;\n      background: var(--cabinet-soft);\n      overflow-wrap: anywhere;\n    }\n\n    .status-tile span,\n    .card-kicker {\n      color: var(--cabinet-muted);\n      font-size: 12px;\n      font-weight: 800;\n      letter-spacing: 0;\n      text-transform: uppercase;\n    }\n\n    .status-tile strong {\n      color: var(--cabinet-ink);\n      line-height: 1.35;\n    }\n\n    .cabinet-card {\n      border-radius: 8px;\n      overflow: clip;\n    }\n\n    .card-header,\n    .tasks-header {\n      width: 100%;\n      min-height: 54px;\n      display: flex;\n      align-items: center;\n      justify-content: space-between;\n      gap: 12px;\n      padding: 12px 14px;\n      border: 0;\n      background: var(--cabinet-surface);\n      color: var(--cabinet-ink);\n      text-align: left;\n      font: inherit;\n    }\n\n    .card-header {\n      cursor: pointer;\n      border-bottom: 1px solid transparent;\n    }\n\n    .card-header:focus-visible,\n    .button:focus-visible,\n    input:focus-visible,\n    select:focus-visible {\n      outline: 3px solid rgba(8, 122, 140, 0.24);\n      outline-offset: 2px;\n    }\n\n    .card-title {\n      display: grid;\n      gap: 4px;\n      min-width: 0;\n    }\n\n    .card-title strong {\n      color: var(--cabinet-ink);\n      font-size: 17px;\n      line-height: 1.25;\n    }\n\n    .card-title span {\n      color: var(--cabinet-muted);\n      font-size: 13px;\n      line-height: 1.35;\n    }\n\n    .card-indicator {\n      min-width: 34px;\n      min-height: 34px;\n      display: grid;\n      place-items: center;\n      flex: 0 0 auto;\n      border: 1px solid var(--cabinet-line);\n      border-radius: 999px;\n      color: var(--cabinet-primary-dark);\n      font-weight: 900;\n    }\n\n    .cabinet-card[open] .card-header {\n      border-bottom-color: var(--cabinet-line);\n    }\n\n    .cabinet-card[open] .card-indicator {\n      transform: rotate(45deg);\n    }\n\n    .card-body,\n    .tasks-body {\n      display: grid;\n      gap: 10px;\n      padding: 12px 14px;\n    }\n\n    .task-list,\n    .document-list,\n    .service-list,\n    .profile-grid,\n    .workspace-grid {\n      display: grid;\n      gap: 10px;\n    }\n\n    .profile-grid {\n      grid-template-columns: repeat(2, minmax(0, 1fr));\n    }\n\n    .workspace-section {\n      display: grid;\n      gap: 10px;\n      padding: 12px;\n      border: 1px solid var(--cabinet-line);\n      border-radius: 8px;\n      background: var(--cabinet-soft);\n    }\n\n    .workspace-section h3 {\n      margin-bottom: 0;\n      color: var(--cabinet-ink);\n      font-size: 16px;\n      line-height: 1.3;\n    }\n\n    .workspace-section-grid {\n      display: grid;\n      grid-template-columns: repeat(2, minmax(0, 1fr));\n      gap: 8px;\n    }\n\n    .workspace-record-list {\n      display: grid;\n      gap: 8px;\n    }\n\n    .profile-identity-card {\n      grid-column: 1 / -1;\n      display: grid;\n      grid-template-columns: auto minmax(0, 1fr);\n      gap: 14px;\n      align-items: center;\n      padding: 12px;\n      border: 1px solid var(--cabinet-line);\n      border-radius: 8px;\n      background: var(--cabinet-soft);\n    }\n\n    .profile-avatar {\n      width: 56px;\n      height: 56px;\n      display: grid;\n      place-items: center;\n      border-radius: 999px;\n      background: var(--cabinet-primary);\n      color: #fff;\n      font-weight: 900;\n      font-size: 20px;\n      overflow: hidden;\n    }\n\n    .profile-avatar img {\n      width: 100%;\n      height: 100%;\n      display: block;\n      border-radius: inherit;\n      object-fit: cover;\n    }\n\n    .profile-identity-copy {\n      display: grid;\n      gap: 7px;\n      min-width: 0;\n    }\n\n    .profile-identity-copy h3 {\n      margin-bottom: 0;\n    }\n\n    .profile-photo-tools {\n      display: grid;\n      grid-template-columns: minmax(220px, 1fr) auto;\n      gap: 10px;\n      align-items: end;\n      max-width: 640px;\n    }\n\n    .profile-photo-tools input {\n      min-width: 0;\n    }\n\n    .task-item,\n    .document-item,\n    .service-item {\n      display: grid;\n      gap: 10px;\n      padding: 12px;\n      border-radius: 8px;\n      box-shadow: none;\n    }\n\n    .task-item.is-action {\n      border-color: var(--cabinet-warning-line);\n      background: var(--cabinet-warning-bg);\n    }\n\n    .task-item.is-waiting {\n      border-color: #8ab8c6;\n      background: #f0f9fb;\n    }\n\n    .task-item h3,\n    .document-item h3,\n    .service-item h3 {\n      margin-bottom: 0;\n      color: var(--cabinet-ink);\n      font-size: 17px;\n      line-height: 1.3;\n      overflow-wrap: anywhere;\n    }\n\n    .meta-row {\n      display: flex;\n      flex-wrap: wrap;\n      gap: 8px;\n    }\n\n    .chip {\n      display: inline-flex;\n      align-items: center;\n      min-height: 30px;\n      padding: 5px 9px;\n      border: 1px solid var(--cabinet-line);\n      border-radius: 999px;\n      background: var(--cabinet-soft);\n      color: var(--cabinet-muted);\n      font-size: 13px;\n      line-height: 1.35;\n    }\n\n    .chip.action {\n      border-color: var(--cabinet-warning-line);\n      color: #704100;\n      background: #fff8e8;\n    }\n\n    .chip.ok {\n      border-color: #8cc7aa;\n      color: var(--cabinet-success);\n      background: #f0fbf5;\n    }\n\n    .task-upload {\n      display: grid;\n      grid-template-columns: minmax(220px, 1fr) auto;\n      gap: 10px;\n      align-items: end;\n    }\n\n    .field {\n      display: grid;\n      gap: 6px;\n    }\n\n    .field strong {\n      color: var(--cabinet-ink);\n      font-size: 13px;\n    }\n\n    input,\n    select {\n      width: 100%;\n      min-height: 42px;\n      padding: 9px 10px;\n      border: 1px solid var(--cabinet-line-strong);\n      border-radius: 8px;\n      background: #fff;\n      color: var(--cabinet-ink);\n      font: inherit;\n    }\n\n    .button {\n      min-height: 42px;\n      display: inline-grid;\n      place-items: center;\n      padding: 0 14px;\n      border: 1px solid transparent;\n      border-radius: 8px;\n      background: var(--cabinet-primary);\n      color: #fff;\n      font: inherit;\n      font-weight: 900;\n      text-decoration: none;\n      cursor: pointer;\n    }\n\n    .button:hover {\n      background: var(--cabinet-primary-dark);\n    }\n\n    .button.secondary {\n      border-color: var(--cabinet-line-strong);\n      background: #fff;\n      color: var(--cabinet-ink);\n    }\n\n    .button:disabled {\n      cursor: not-allowed;\n      opacity: 0.58;\n    }\n\n    .empty-state {\n      padding: 14px;\n      border: 1px dashed var(--cabinet-line-strong);\n      border-radius: 8px;\n      color: var(--cabinet-muted);\n      background: var(--cabinet-soft);\n      line-height: 1.55;\n    }\n\n    .status-line {\n      min-height: 22px;\n      margin: 0;\n      color: var(--cabinet-muted);\n      font-weight: 700;\n      line-height: 1.45;\n    }\n\n    .status-line.ok {\n      color: var(--cabinet-success);\n    }\n\n    .status-line.error {\n      color: var(--cabinet-danger);\n    }\n\n    [hidden] {\n      display: none !important;\n    }\n\n    @media (max-width: 860px) {\n      .cabinet-header,\n      .cabinet-status,\n      .profile-grid,\n      .workspace-section-grid,\n      .profile-photo-tools,\n      .task-upload,\n      .profile-identity-card {\n        grid-template-columns: 1fr;\n      }\n\n      .cabinet-header {\n        align-items: stretch;\n      }\n\n      .header-actions,\n      .button {\n        width: 100%;\n      }\n\n      .header-actions {\n        align-items: stretch;\n      }\n\n      .header-actions > *,\n      .header-actions .cpg-theme-switcher,\n      .header-actions .cpg-theme-switcher__summary,\n      .header-actions .cpg-account,\n      .header-actions .cpg-account__summary {\n        width: 100%;\n      }\n\n      .profile-avatar {\n        width: 56px;\n        height: 56px;\n      }\n    }\n\n    html[data-cpg-theme=\"dark\"] .cabinet-header,\n    html[data-cpg-theme=\"dark\"] .cabinet-status,\n    html[data-cpg-theme=\"dark\"] .cabinet-card,\n    html[data-cpg-theme=\"dark\"] .task-item,\n    html[data-cpg-theme=\"dark\"] .document-item,\n    html[data-cpg-theme=\"dark\"] .service-item {\n      box-shadow: 0 20px 60px rgba(3, 11, 20, 0.34);\n    }\n\n    html[data-cpg-theme=\"dark\"] input,\n    html[data-cpg-theme=\"dark\"] select {\n      background: rgba(7, 17, 28, 0.72);\n      color: var(--cabinet-ink);\n    }\n\n    html[data-cpg-theme=\"dark\"] .button.secondary {\n      background: var(--cabinet-soft);\n      color: var(--cabinet-ink);\n    }\n\n    html[data-cpg-theme=\"dark\"] .chip.action {\n      color: var(--cabinet-warning-line);\n      background: rgba(255, 210, 138, 0.12);\n    }\n\n    html[data