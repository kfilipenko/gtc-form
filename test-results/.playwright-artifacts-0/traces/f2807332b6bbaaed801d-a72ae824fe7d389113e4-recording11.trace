\n    .queue-table { width: 100%; border-collapse: collapse; min-width: 900px; }\n    .queue-table th, .queue-table td { border-bottom: 1px solid var(--line); padding: 10px 8px; text-align: left; color: var(--muted-on-dark); }\n    .queue-table th { color: var(--text-on-dark); font-weight: 600; }\n    .queue-type { font-size: 12px; border: 1px solid var(--line); border-radius: 999px; padding: 2px 10px; display: inline-block; }\n    .operator-access {\n      display: grid;\n      grid-template-columns: minmax(0, 1fr) auto;\n      gap: 12px;\n      align-items: end;\n      margin-top: 18px;\n      padding: 14px;\n      border: 1px solid var(--line);\n      border-radius: 12px;\n      background: rgba(0, 102, 128, 0.12);\n    }\n    .operator-access[hidden] { display: none; }\n    .operator-access__field {\n      display: grid;\n      gap: 6px;\n    }\n    .operator-access__field label {\n      color: var(--text-on-dark);\n      font-weight: 700;\n    }\n    .operator-access__field input {\n      width: 100%;\n      padding: 11px 12px;\n      border-radius: 10px;\n      border: 1px solid var(--line);\n      background: rgba(255, 255, 255, 0.07);\n      color: var(--text-on-dark);\n      font: inherit;\n    }\n    .operator-access__feedback {\n      grid-column: 1 / -1;\n      margin: 0;\n      color: var(--muted-on-dark);\n      min-height: 20px;\n    }\n    .details-card {\n      margin-top: 18px;\n      border: 1px solid var(--line);\n      border-radius: 14px;\n      padding: 16px;\n      background: rgba(255, 255, 255, 0.04);\n    }\n    .details-title {\n      margin: 0 0 8px;\n      color: var(--text-on-dark);\n    }\n    .details-sections {\n      display: grid;\n      gap: 14px;\n      margin-bottom: 16px;\n    }\n    .details-empty {\n      margin: 0;\n      color: var(--muted-on-dark);\n      line-height: 1.6;\n    }\n    .detail-section {\n      display: grid;\n      gap: 12px;\n      padding: 14px;\n      border: 1px solid var(--line);\n      border-radius: 12px;\n      background: rgba(255, 255, 255, 0.04);\n    }\n    .detail-section h3 {\n      margin: 0;\n      color: var(--text-on-dark);\n      font-size: 18px;\n      line-height: 1.25;\n    }\n    .detail-grid {\n      display: grid;\n      grid-template-columns: repeat(3, minmax(0, 1fr));\n      gap: 10px;\n    }\n    .detail-field {\n      display: grid;\n      gap: 4px;\n      min-height: 66px;\n      padding: 10px;\n      border: 1px solid var(--line);\n      border-radius: 10px;\n      background: rgba(255, 255, 255, 0.04);\n    }\n    .detail-label {\n      color: var(--muted-on-dark);\n      font-size: 12px;\n      line-height: 1.35;\n    }\n    .detail-value {\n      color: var(--text-on-dark);\n      font-weight: 700;\n      line-height: 1.35;\n      overflow-wrap: anywhere;\n    }\n    .detail-value.muted {\n      color: var(--muted-on-dark);\n      font-weight: 500;\n    }\n    .raw-details {\n      margin-top: 12px;\n      border: 1px solid var(--line);\n      border-radius: 12px;\n      padding: 10px 12px;\n      background: rgba(255, 255, 255, 0.03);\n    }\n    .raw-details summary {\n      cursor: pointer;\n      color: var(--text-on-dark);\n      font-weight: 700;\n    }\n    .details-json {\n      margin: 12px 0 0;\n      color: var(--muted-on-dark);\n      white-space: pre-wrap;\n      word-break: break-word;\n      font-size: 13px;\n      line-height: 1.5;\n    }\n    .review-note-block {\n      margin-bottom: 14px;\n      display: grid;\n      gap: 8px;\n    }\n    .review-note-label {\n      color: var(--text-on-dark);\n      font-size: 13px;\n    }\n    .review-note-textarea {\n      width: 100%;\n      min-height: 88px;\n      padding: 10px 12px;\n      border-radius: 12px;\n      border: 1px solid var(--line);\n      background: rgba(255, 255, 255, 0.06);\n      color: var(--text-on-dark);\n      font: inherit;\n      resize: vertical;\n    }\n    .review-note-select {\n      width: 100%;\n      padding: 10px 12px;\n      border-radius: 12px;\n      border: 1px solid var(--line);\n      background: rgba(255, 255, 255, 0.06);\n      color: var(--text-on-dark);\n      font: inherit;\n    }\n    .review-card-actions {\n      display: flex;\n      flex-wrap: wrap;\n      gap: 8px;\n    }\n    .review-card-action[disabled] {\n      cursor: not-allowed;\n      opacity: 0.52;\n    }\n    .review-note-feedback {\n      margin: 0;\n      color: #f4b942;\n      font-size: 13px;\n    }\n    .queue-decision[disabled] {\n      cursor: not-allowed;\n      opacity: 0.52;\n    }\n    .latest-note {\n      margin: 0;\n      color: var(--muted-on-dark);\n      font-size: 13px;\n      line-height: 1.5;\n    }\n    .history-panel {\n      margin-top: 8px;\n      border: 1px solid var(--line);\n      border-radius: 12px;\n      padding: 10px;\n      background: rgba(255, 255, 255, 0.03);\n    }\n    .history-title {\n      margin: 0 0 8px;\n      color: var(--text-on-dark);\n      font-size: 13px;\n      font-weight: 600;\n    }\n    .history-empty {\n      margin: 0;\n      color: var(--muted-on-dark);\n      font-size: 13px;\n    }\n    .history-list {\n      margin: 0;\n      padding-left: 18px;\n      display: grid;\n      gap: 6px;\n      color: var(--muted-on-dark);\n      font-size: 13px;\n    }\n    .history-item-note {\n      color: var(--text-on-dark);\n    }\n    @media (max-width: 980px) {\n      .queue-controls {\n        grid-template-columns: 1fr;\n      }\n      .detail-grid {\n        grid-template-columns: 1fr;\n      }\n      .operator-access {\n        grid-template-columns: 1fr;\n      }\n    }\n  "],"\n  ",["LINK",{"rel":"stylesheet","href":"../assets/crewportglobal-app.css"}],"\n"],"\n",["BODY",{"class":"doc-body cpg-app-page"},"\n  ",["DIV",{"class":"site-shell"},"\n    ",["HEADER",{"class":"site-header"},"\n      ",["A",{"class":"brand","href":"https://crewportglobal.com/"},"\n        ",["SPAN",{"class":"brand-mark"},"CPG"],"\n        ",["SPAN",{"class":"brand-copy"},"\n          ",["STRONG",{}