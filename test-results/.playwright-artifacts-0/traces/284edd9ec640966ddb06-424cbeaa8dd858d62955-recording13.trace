     background: rgba(255, 255, 255, 0.04);\n    }\n\n    .lead-copy,\n    .status-box,\n    .step-card p,\n    .step-card li {\n      color: var(--muted-on-dark);\n      line-height: 1.6;\n    }\n\n    .step-card ul {\n      margin: 0;\n      padding-left: 18px;\n      display: grid;\n      gap: 8px;\n    }\n\n    .inline-actions {\n      display: flex;\n      flex-wrap: wrap;\n      gap: 12px;\n    }\n\n    .vacancy-form {\n      display: grid;\n      gap: 18px;\n      margin-top: 18px;\n    }\n\n    .field-grid {\n      display: grid;\n      grid-template-columns: repeat(2, minmax(0, 1fr));\n      gap: 12px;\n    }\n\n    .field-card {\n      display: grid;\n      gap: 8px;\n      padding: 16px;\n      border-radius: 16px;\n      border: 1px solid var(--line);\n      background: rgba(255, 255, 255, 0.04);\n    }\n\n    .field-card.full {\n      grid-column: 1 / -1;\n    }\n\n    .field-card input,\n    .field-card select,\n    .field-card textarea {\n      width: 100%;\n      padding: 12px 14px;\n      border-radius: 14px;\n      border: 1px solid var(--line);\n      background: rgba(255, 255, 255, 0.08);\n      color: var(--text-on-dark);\n      font: inherit;\n    }\n\n    .field-card textarea {\n      min-height: 118px;\n      resize: vertical;\n    }\n\n    .document-upload-panel {\n      display: grid;\n      gap: 14px;\n      padding: 14px;\n      border-radius: 12px;\n      border: 1px solid var(--line);\n      background: rgba(255, 255, 255, 0.04);\n    }\n\n    .document-upload-grid {\n      display: grid;\n      grid-template-columns: minmax(180px, 0.38fr) minmax(220px, 1fr) auto;\n      gap: 10px;\n      align-items: end;\n    }\n\n    .document-upload-list {\n      display: grid;\n      gap: 10px;\n    }\n\n    .document-action-list {\n      display: grid;\n      gap: 10px;\n    }\n\n    .document-action-task {\n      display: grid;\n      gap: 10px;\n      padding: 14px;\n      border-radius: 10px;\n      border: 1px solid rgba(255, 189, 89, 0.72);\n      background: rgba(255, 189, 89, 0.14);\n    }\n\n    .document-action-task strong {\n      color: var(--text-on-dark);\n      overflow-wrap: anywhere;\n    }\n\n    .document-action-task p {\n      margin: 0;\n      color: var(--muted-on-dark);\n      line-height: 1.5;\n    }\n\n    .document-action-task__meta {\n      display: grid;\n      gap: 4px;\n    }\n\n    .document-action-task__actions {\n      display: flex;\n      flex-wrap: wrap;\n      gap: 8px;\n      align-items: center;\n    }\n\n    .document-upload-item {\n      display: grid;\n      gap: 8px;\n      padding: 12px;\n      border-radius: 10px;\n      border: 1px solid var(--line);\n      background: rgba(0, 102, 128, 0.1);\n    }\n\n    .document-upload-item strong {\n      color: var(--text-on-dark);\n      overflow-wrap: anywhere;\n    }\n\n    .document-upload-meta {\n      display: flex;\n      flex-wrap: wrap;\n      gap: 8px;\n      color: var(--muted-on-dark);\n      font-size: 13px;\n      line-height: 1.45;\n    }\n\n    .document-upload-meta span {\n      padding: 6px 8px;\n      border-radius: 999px;\n      border: 1px solid var(--line);\n      background: rgba(255, 255, 255, 0.04);\n    }\n\n    .workspace-status-grid {\n      display: grid;\n      grid-template-columns: repeat(4, minmax(0, 1fr));\n      gap: 10px;\n      margin-top: 14px;\n    }\n\n    .workspace-status-card {\n      display: grid;\n      gap: 6px;\n      min-height: 86px;\n      padding: 12px;\n      border-radius: 12px;\n      border: 1px solid var(--line);\n      background: rgba(0, 102, 128, 0.12);\n    }\n\n    .workspace-status-card span {\n      color: var(--muted-on-dark);\n      font-size: 12px;\n      line-height: 1.35;\n    }\n\n    .workspace-status-card strong {\n      color: var(--text-on-dark);\n      line-height: 1.35;\n      overflow-wrap: anywhere;\n    }\n\n    .workspace-next-action {\n      grid-column: 1 / -1;\n      display: grid;\n      gap: 6px;\n      padding: 12px;\n      border-radius: 12px;\n      border: 1px solid var(--line);\n      background: rgba(255, 255, 255, 0.04);\n    }\n\n    .workspace-next-action span {\n      color: var(--muted-on-dark);\n      font-size: 12px;\n    }\n\n    .workspace-next-action strong {\n      color: var(--text-on-dark);\n      line-height: 1.5;\n    }\n\n    .candidate-pipeline {\n      display: grid;\n      gap: 12px;\n      margin-top: 14px;\n      padding: 14px;\n      border-radius: 12px;\n      border: 1px solid var(--line);\n      background: rgba(255, 255, 255, 0.04);\n    }\n\n    .candidate-pipeline__head {\n      display: flex;\n      flex-wrap: wrap;\n      gap: 8px 12px;\n      align-items: baseline;\n      justify-content: space-between;\n    }\n\n    .candidate-pipeline__head span,\n    .candidate-pipeline__copy,\n    .candidate-card__meta,\n    .candidate-card__note {\n      color: var(--muted-on-dark);\n      line-height: 1.55;\n    }\n\n    .candidate-pipeline__head span {\n      font-size: 12px;\n    }\n\n    .candidate-pipeline__head strong,\n    .candidate-card h3 {\n      color: var(--text-on-dark);\n    }\n\n    .candidate-pipeline__copy {\n      margin: 0;\n      font-size: 14px;\n    }\n\n    .candidate-list {\n      display: grid;\n      gap: 10px;\n    }\n\n    .candidate-card {\n      display: grid;\n      gap: 10px;\n      padding: 12px;\n      border-radius: 10px;\n      border: 1px solid var(--line);\n      background: rgba(0, 102, 128, 0.1);\n    }\n\n    .candidate-card h3,\n    .candidate-card p {\n      margin: 0;\n    }\n\n    .candidate-card__meta {\n      display: flex;\n      flex-wrap: wrap;\n      gap: 8px;\n      font-size: 13px;\n    }\n\n    .candidate-card__meta span {\n      padding: 6px 8px;\n      border-radius: 999px;\n      border: 1px solid var(--line);\n      background: rgba(255, 255, 255, 0.04);\n    }\n\n    .candidate-card__note {\n      font-size: 14px;\n    }\n\n    .candidate-card__followup {\n      display: grid;\n      gap: 6px;\n    }\n\n    .candidate-card__followup strong {\n      color: var(--text-on-dark);\n      font-size: 13px;\n    }\n\n    .candidate-card__followup textarea {\n      width: 100%;\n      min-height: 82px;\n      padding: 10px 12px;\n      border-radius: 10px;\n      border: 1px solid var(--line);\n      background: rgba(255, 255, 255, 0.08);\n      color: var(--text-on-dark);\n      font: inherit;\n      resize: vertical;\n    }\n\n    .candidate-card__actions {\n      display: flex;\n      flex-wrap: wrap;\n      gap: 8px;\n      align-items: center;\n    }\n\n    .candidate-card__actions .button {\n      min-height: 36px;\n      padding: 8px 10px;\n      border-radius: 8px;\n      font-size: 13px;\n    }\n\n    @media (max-width: 980px) {\n      .flow-grid,\n      .step-grid,\n      .field-grid,\n      .document-upload-grid,\n      .workspace-status-grid {\n        grid-template-columns: 1fr;\n      }\n    }\n  "],"\n  ",["LINK",{"rel":"stylesheet","href":"../assets/crewportglobal-app.css"}],"\n"],"\n",["BODY",{"class":"doc-body cpg-app-page"},"\n  ",["DIV",{"class":"site-shell"},"\n    ",["HEADER",{"class":"site-header"},"\n      ",["A",{"class":"brand","href":"https://crewportglobal.com/"},"\n        ",["SPAN",{"class":"brand-mark"},"CPG"],"\n        ",["SPAN",{"class":"brand-copy"},"\n          ",["STRONG",{},"CrewPortGlobal"],"\n          ",["SPAN",{"data-i18n":"site.tagline"},"Maritime jobs and crew platform"],"\n        "],"\n      "],"\n      ",["DIV",{"class":"site-header__actions"},["DIV",{"data-cpg-theme-switcher":""},["DETAILS",{"class":"cpg-theme-switcher","data-cpg-theme-switcher-menu":""},"\n  ",["SUMMARY",{"class":"cpg-theme-switcher__summary"},"\n    ",["SPAN",{"class":"cpg-theme-switcher__label"},"Theme"],"\n    ",["SPAN",{"class":"cpg-theme-switcher__value"},"Dark"],"\n    ",["SPAN",{"class":"cpg-theme-switcher__chevron","aria-hidden":"true"},"▾"],"\n  "],"\n  ",["DIV",{"class":"cpg-theme-switcher__panel"},"\n    ",["BUTTON",{"class":"cpg-theme-option","type":"button","da