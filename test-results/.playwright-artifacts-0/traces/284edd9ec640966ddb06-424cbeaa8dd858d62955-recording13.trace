     overflow-wrap: anywhere;\n    }\n\n    .document-action-task p {\n      margin: 0;\n      color: var(--muted-on-dark);\n      line-height: 1.5;\n    }\n\n    .document-action-task__meta {\n      display: grid;\n      gap: 4px;\n    }\n\n    .document-action-task__actions {\n      display: flex;\n      flex-wrap: wrap;\n      gap: 8px;\n      align-items: center;\n    }\n\n    .document-upload-item {\n      display: grid;\n      gap: 8px;\n      padding: 12px;\n      border-radius: 10px;\n      border: 1px solid var(--line);\n      background: rgba(0, 102, 128, 0.1);\n    }\n\n    .document-upload-item strong {\n      color: var(--text-on-dark);\n      overflow-wrap: anywhere;\n    }\n\n    .document-upload-meta {\n      display: flex;\n      flex-wrap: wrap;\n      gap: 8px;\n      color: var(--muted-on-dark);\n      font-size: 13px;\n      line-height: 1.45;\n    }\n\n    .document-upload-meta span {\n      padding: 6px 8px;\n      border-radius: 999px;\n      border: 1px solid var(--line);\n      background: rgba(255, 255, 255, 0.04);\n    }\n\n    .workspace-status-grid {\n      display: grid;\n      grid-template-columns: repeat(4, minmax(0, 1fr));\n      gap: 10px;\n      margin-top: 14px;\n    }\n\n    .workspace-status-card {\n      display: grid;\n      gap: 6px;\n      min-height: 86px;\n      padding: 12px;\n      border-radius: 12px;\n      border: 1px solid var(--line);\n      background: rgba(0, 102, 128, 0.12);\n    }\n\n    .workspace-status-card span {\n      color: var(--muted-on-dark);\n      font-size: 12px;\n      line-height: 1.35;\n    }\n\n    .workspace-status-card strong {\n      color: var(--text-on-dark);\n      line-height: 1.35;\n      overflow-wrap: anywhere;\n    }\n\n    .workspace-next-action {\n      grid-column: 1 / -1;\n      display: grid;\n      gap: 6px;\n      padding: 12px;\n      border-radius: 12px;\n      border: 1px solid var(--line);\n      background: rgba(255, 255, 255, 0.04);\n    }\n\n    .workspace-next-action 