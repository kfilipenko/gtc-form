\n      font-size: 10px;\n    }\n\n    .language-toggle__label {\n      font-size: 13px;\n      font-weight: 600;\n    }\n\n    .language-toggle__chevron {\n      font-size: 11px;\n      color: var(--muted-on-dark);\n      transition: transform 180ms ease;\n    }\n\n    .language-selector.is-open .language-toggle__chevron {\n      transform: rotate(180deg);\n    }\n\n    .language-menu {\n      position: absolute;\n      top: calc(100% + 10px);\n      inset-inline-end: 0;\n      width: min(260px, calc(100vw - 32px));\n      padding: 10px;\n      border: 1px solid var(--line);\n      border-radius: 20px;\n      background: rgba(22, 40, 61, 0.96);\n      box-shadow: 0 20px 44px rgba(0, 0, 0, 0.28);\n      z-index: 40;\n    }\n\n    .language-menu[hidden] {\n      display: none;\n    }\n\n    .language-menu__options {\n      display: grid;\n      gap: 8px;\n    }\n\n    .language-option {\n      width: 100%;\n      display: flex;\n      align-items: center;\n      gap: 10px;\n      padding: 10px 12px;\n      border: 1px solid transparent;\n      border-radius: 14px;\n      background: transparent;\n      color: var(--text-on-dark);\n      text-align: left;\n      cursor: pointer;\n    }\n\n    .language-option.is-current {\n      border-color: rgba(255, 255, 255, 0.14);\n      background: rgba(255, 255, 255, 0.1);\n    }\n\n    .language-option__label {\n      font-weight: 600;\n    }\n\n    .landing-hero {\n      display: grid;\n      grid-template-columns: 1.25fr 0.95fr;\n      gap: 24px;\n      align-items: stretch;\n    }\n\n    .hero-copy {\n      padding: 40px;\n    }\n\n    .landing-title {\n      margin: 0 0 18px;\n      font-size: clamp(40px, 7vw, 72px);\n      line-height: 0.94;\n      letter-spacing: -0.05em;\n      max-width: 10ch;\n      color: var(--paper-strong);\n    }\n\n    .landing-lead {\n      margin: 0 0 28px;\n      max-width: 58ch;\n      font-size: 18px;\n      line-height: 1.65;\n      color: var(--muted-on-dark);\n    }\n\n    .actions {\n      display: flex;\n      flex-wrap: wrap;\n      gap: 12px;\n      margin-bottom: 28px;\n    }\n\n    .hero-panel {\n      padding: 26px;\n      display: grid;\n      gap: 16px;\n    }\n\n    .hero-panel section {\n      padding: 20px;\n      border-radius: 20px;\n      background: rgba(255, 255, 255, 0.04);\n      border: 1px solid var(--line);\n    }\n\n    .hero-panel h2,\n    .docs-head h2,\n    .verification-card strong,\n    .doc-title {\n      margin: 0 0 10px;\n      font-size: 22px;\n      letter-spacing: -0.03em;\n      color: var(--paper-strong);\n    }\n\n    .docs {\n      margin-top: 24px;\n      padding: 28px;\n    }\n\n    .docs-head {\n      display: flex;\n      justify-content: space-between;\n      align-items: end;\n      gap: 16px;\n      margin-bottom: 18px;\n    }\n\n    .docs-head > p,\n    .hero-panel p,\n    .doc-note,\n    .verification-band .docs-head p {\n      color: var(--muted-on-dark);\n      line-height: 1.6;\n    }\n\n    .doc-list {\n      display: grid;\n      grid-template-columns: repeat(3, minmax(0, 1fr));\n      gap: 14px;\n      padding: 0;\n      margin: 0;\n      list-style: none;\n    }\n\n    .doc-list li {\n      min-height: 140px;\n    }\n\n    .doc-list a {\n      display: flex;\n      flex-direction: column;\n      justify-content: space-between;\n      height: 100%;\n      padding: 20px;\n      border-radius: 20px;\n      background: rgba(255, 255, 255, 0.04);\n      border: 1px solid var(--line);\n      color: inherit;\n      text-decoration: none;\n    }\n\n    .doc-type {\n      font-size: 12px;\n      letter-spacing: 0.12em;\n      text-transform: uppercase;\n      color: var(--amber);\n    }\n\n    .verification-band {\n      margin-top: 24px;\n      padding: 28px;\n    }\n\n    .verification-grid {\n      display: grid;\n      grid-template-columns: repeat(3, minmax(0, 1fr));\n      gap: 14px;\n      margin-top: 18px;\n    }\n\n    .verification-card {\n      display: flex;\n      flex-direction: column;\n   