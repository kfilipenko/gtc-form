ary","href":"https://crewportglobal.com/post-vacancy/","data-i18n":"home.board.card2.cta"},"Prepare Vacancy Request"],"\n            "],"\n          "],"\n          ",["ARTICLE",{"class":"vacancy-card"},"\n            ",["DIV",{},"\n              ",["P",{"class":"eyebrow","data-i18n":"home.board.card3.eyebrow"},"Seafarer next step"],"\n              ",["H3",{"data-i18n":"home.board.card3.title"},"Prepare your profile before vacancies open"],"\n            "],"\n            ",["P",{"class":"empty-state","data-i18n":"home.board.card3.copy"},"Keep your CV, availability, certificates and contact details ready so you can apply when live vacancies appear."],"\n            ",["SPAN",{"class":"vacancy-status","data-i18n":"home.board.card3.status"},"Profile-ready path"],"\n            ",["DIV",{"class":"mini-actions"},"\n              ",["A",{"class":"button secondary","href":"https://crewportglobal.com/create-profile/","data-i18n":"home.board.card3.cta"},"Create Seafarer Profile"],"\n            "],"\n          "],"\n        "],"\n      "],"\n\n      ",["SECTION",{"class":"value-grid"},"\n        ",["ARTICLE",{"class":"card value-panel value-card"},"\n          ",["P",{"class":"eyebrow","data-i18n":"home.value.employers.eyebrow"},"For employers"],"\n          ",["H3",{"data-i18n":"home.value.employers.title"},"Move from crew need to a structured vacancy request."],"\n          ",["UL",{"class":"feature-list"},"\n            ",["LI",{"data-i18n":"home.value.employers.item1"},"Present company details and employer context clearly."],"\n            ",["LI",{"data-i18n":"home.value.employers.item2"},"Define rank, vessel type, salary, joining date and duration."],"\n            ",["LI",{"data-i18n":"home.value.employers.item3"},"Share requirements before wider publication."],"\n            ",["LI",{"data-i18n":"home.value.employers.item4"},"Review prepared seafarer profiles after human review."],"\n            ",["LI",{"data-i18n":"home.value.employers.item5"},"Keep communication controlled and professional."],"\n            ",["LI",{"data-i18n":"home.value.employers.item6"},"Use verification and trust rules before live publication."],"\n          "],"\n          ",["DIV",{"class":"mini-actions"},"\n            ",["A",{"class":"button primary","href":"https://crewportglobal.com/post-vacancy/","data-i18n":"home.value.employers.cta"},"Prepare Vacancy Request"],"\n          "],"\n        "],"\n        ",["ARTICLE",{"class":"card value-panel value-card"},"\n          ",["P",{"class":"eyebrow","data-i18n":"home.value.seafarers.eyebrow"},"For seafarers"],"\n          ",["H3",{"data-i18n":"home.value.seafarers.title"},"Build a profile that is ready for serious review."],"\n          ",["UL",{"class":"feature-list"},"\n            ",["LI",{"data-i18n":"home.value.seafarers.item1"},"Create an online CV with rank, availability and contact basics."],"\n            ",["LI",{"data-i18n":"home.value.seafarers.item2"},"Add certificate and document metadata in one place."],"\n            ",["LI",{"data-i18n":"home.value.seafarers.item3"},"Keep completeness and acknowledgements visible."],"\n            ",["LI",{"data-i18n":"home.value.seafarers.item4"},"Submit your profile for human review."],"\n            ",["LI",{"data-i18n":"home.value.seafarers.item5"},"Prepare before public vacancies go live."],"\n            ",["LI",{"data-i18n":"home.value.seafarers.item6"},"Keep the no-recruitment-fee rule visible from the start."],"\n          "],"\n          ",["DIV",{"class":"mini-actions"},"\n            ",["A",{"class":"button primary","href":"https://crewportglobal.com/create-profile/","data-i18n":"home.value.seafarers.cta"},"Create Seafarer Profile"],"\n          "],"\n        "],"\n        ",["ARTICLE",{"class":"card value-panel value-card"},"\n          ",["P",{"class":"eyebrow","data-i18n":"home.value.workflow.eyebrow"},"How the platform works"],"\n          ",["H3",{"data-i18n":"home.value.workflow.title"},"Useful actions first, trust rules always visible."],"\n          ",["UL",{"class":"feature-list"},"\n            ",["LI",{"data-i18n":"home.value.workflow.item1"},"Create a profile, prepare a vacancy request or open the vacancy board immediately."],"\n            ",["LI",{"data-i18n":"home.value.workflow.item2"},"Keep trust, verification and no-fee rules visible inside each step."],"\n            ",["LI",{"data-i18n":"home.value.workflow.item3"},"Do not imply automatic approval, automatic matching or automatic employment."],"\n            ",["LI",{"data-i18n":"home.value.workflow.item4"},"Use human review when readiness or candidate presentation matters."],"\n          "],"\n          ",["DIV",{"class":"mini-actions"},"\n            ",["A",{"class":"button secondary","href":"https://crewportglobal.com/how-it-works/","data-i18n":"home.value.workflow.cta"},"Review Workflow"],"\n          "],"\n        "],"\n      "],"\n\n      ",["SECTION",{"class":"trust-grid"},"\n        ",["ARTICLE",{"class":"card trust-panel trust-card"},"\n          ",["P",{"class":"eyebrow"},"Trust & Safety"],"\n          ",["H3",{"data-i18n":"home.trust.fees.title"},"No recruitment fee promise stays explicit."],"\n          ",["P",{"class":"support-copy","data-i18n":"home.trust.fees.copy"},"Seafarers do not pay recruitment, placement or employment-access fees to create a profile or apply through CrewPortGlobal."],"\n        "],"\n        ",["ARTICLE",{"class":"card trust-panel trust-card"},"\n          ",["P",{"class":"eyebrow","data-i18n":"home.trust.review.eyebrow"},"Human review"],"\n          ",["H3",{"data-i18n":"home.trust.review.title"},"Approval does not happen automatically."],"\n          ",["P",{"class":"support-copy","data-i18n":"home.trust.review.copy"},"Profiles and vacancy requests are submitted for human review before wider candidate presentation or public publication."],"\n        "],"\n        ",["ARTICLE",{"class":"card trust-panel trust-card"},"\n          ",["P",{"class":"eyebrow","data-i18n":"home.trust.live.eyebrow"}