<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>GTC • News</title>
  <style>
    :root{--bg:#0a0d1e;--panel:#0f1730;--card:#131c3a;--muted:#1b274d;--fg:#fff;--accent:#5b8cff;--accent2:#2c68ff}
    *{box-sizing:border-box}
    body{margin:0;background:var(--bg);color:var(--fg);font-family:system-ui,-apple-system,"Segoe UI",Roboto,Ubuntu,Arial,sans-serif}
    header{display:flex;align-items:center;gap:12px;padding:14px 18px;background:var(--panel);position:sticky;top:0;z-index:5}
    header img{width:28px;height:28px}
    header h1{font-size:1.05rem;margin:0}
    .grid{display:grid;grid-template-columns:320px 1fr;gap:14px;padding:14px}
    @media (max-width:980px){.grid{grid-template-columns:1fr}}
    aside{background:var(--panel);border-radius:12px;overflow:hidden}
    .list{max-height:calc(100vh - 120px);overflow:auto}
    .item{border-bottom:1px solid #22325f;padding:12px 14px;cursor:pointer}
    .item:hover{background:#13224b}
    .item.active{background:#162a5d}
    .item h3{margin:0 0 6px 0;font-size:.98rem;line-height:1.3}
    .item time{opacity:.8;font-size:.85rem}
    main{background:var(--card);border-radius:12px;padding:18px}
    .title{margin:0 0 8px 0;font-size:1.4rem;line-height:1.25}
    .meta{opacity:.85;margin-bottom:14px}
    .article p{margin:0 0 12px 0;line-height:1.55}
    .cta{margin-top:16px;display:flex;flex-wrap:wrap;gap:10px}
    .btn{display:inline-block;padding:10px 14px;border-radius:10px;background:var(--accent);color:#fff;text-decoration:none}
    .btn:hover{background:var(--accent2)}
    .toolbar{display:flex;gap:8px;margin-top:8px}
    .muted{opacity:.8}
    .empty{padding:18px}
    .loader{padding:18px}
    a.clean{display:none}
  </style>
  <link rel="icon" href="/favicon.ico" sizes="any">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
  <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png">
  <link rel="manifest" href="/site.webmanifest">
</head>
<body>
  <header>
    <img src="https://kfilipenko.github.io/gtc-form/assets/logo.png" alt="logo">
    <h1>GTC • News</h1>
  </header>

  <div class="grid">
    <aside>
      <div id="list" class="list"></div>
    </aside>

    <main>
      <h2 id="title" class="title">Loading…</h2>
      <div id="meta" class="meta muted"></div>
      <article id="article" class="article loader">Please wait</article>

      <div id="cta" class="cta"></div>
      <div class="toolbar">
        <a id="openSource" class="btn" href="#" target="_blank" rel="noopener">Open source</a>
        <a id="backToList" class="btn" href="/news/">Back to list</a>
        <a id="home" class="btn" href="/news/">Home</a>
      </div>
    </main>
  </div>

  <script>
    const API = '/api';
    const qs = s => document.querySelector(s);
    const listEl = qs('#list');
    const titleEl = qs('#title');
    const metaEl = qs('#meta');
    const artEl = qs('#article');
    const ctaEl = qs('#cta');
    const openSource = qs('#openSource');

    const fmtDate = iso => {
      try { return new Date(iso).toLocaleString(); } catch { return iso || '' }
    };

    // Render helpers
    function renderList(items, activeId){
      listEl.innerHTML = '';
      if(!Array.isArray(items) || items.length===0){
        listEl.innerHTML = '<div class="empty">No news yet.</div>'; return;
      }
      for(const it of items){
        const div = document.createElement('div');
        div.className = 'item' + (it.news_id===activeId ? ' active': '');
        div.dataset.id = it.news_id;
        div.innerHTML = `
          <h3>${escapeHtml(it.title||'(no title)')}</h3>
          <time datetime="${it.published_at||''}">${fmtDate(it.published_at||it.created_at_web)}</time>
        `;
        div.addEventListener('click', ()=>{
          const url = new URL(location.href);
          url.searchParams.set('news_id', it.news_id);
          history.pushState({}, '', url.toString());
          loadDetail(it.news_id);
          highlightActive(it.news_id);
        });
        listEl.appendChild(div);
      }
    }

    function highlightActive(id){
      listEl.querySelectorAll('.item').forEach(n => {
        n.classList.toggle('active', n.dataset.id === id);
      });
    }

    function renderArticle(item){
      titleEl.textContent = item.title || '(untitled)';
      metaEl.textContent = [item.seo_title, fmtDate(item.published_at || item.created_at_web)]
        .filter(Boolean).join(' • ');
      artEl.classList.remove('loader');
      artEl.innerHTML = toHtmlParagraphs(item.article_web || 'No article text.');

      // CTA buttons
      ctaEl.innerHTML = '';
      const buttons = Array.isArray(item.cta_buttons) ? item.cta_buttons : [];
      for(const b of buttons){
        if(b?.action === 'open_url' && b?.url){
          const a = document.createElement('a');
          a.className = 'btn';
          a.href = b.url; a.target = '_blank'; a.rel = 'noopener';
          a.textContent = b.text || 'Open';
          ctaEl.appendChild(a);
        }
        if(b?.action === 'launch_agent'){
          const a = document.createElement('a');
          a.className = 'btn';
          a.href = 'https://t.me/Procurement_AnalystBot?start=gtc_consumer'; a.target = '_blank'; a.rel = 'noopener'; a.textContent = b.text || 'Ask the AI';
          ctaEl.appendChild(a);
        }
      }

      openSource.href = item.url || '#';
      openSource.classList.toggle('clean', !item.url);
    }

    // HTML helpers
    function escapeHtml(s){
      return String(s||'').replace(/[&<>"']/g, c=>({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' }[c]));
    }
    function toHtmlParagraphs(text){
      return escapeHtml(text).split(/\n{2,}/).map(p=>`<p>${p.replace(/\n/g,'<br>')}</p>`).join('');
    }

    // Data loaders
    async function fetchList(limit=16){
      const q = `${API}/v_news_web?select=news_id,title,published_at,created_at_web&locale=eq.en&order=created_at_web.desc&limit=${limit}`;
      const r = await fetch(q); return await r.json();
    }
    async function fetchOne(id){
      const fields = [
        'news_id','title','url','published_at','created_at_web',
        'article_web','cta_buttons','seo_title','promo_url'
      ].join(',');
      const q = `${API}/v_news_web?news_id=eq.${encodeURIComponent(id)}&select=${fields}&limit=1`;
      const r = await fetch(q); const arr = await r.json();
      return Array.isArray(arr) && arr[0] || null;
    }
    async function fetchLatest(){
      const fields = [
        'news_id','title','url','published_at','created_at_web',
        'article_web','cta_buttons','seo_title','promo_url'
      ].join(',');
      const q = `${API}/v_news_web?select=${fields}&locale=eq.en&order=created_at_web.desc&limit=1`;
      const r = await fetch(q); const arr = await r.json();
      return Array.isArray(arr) && arr[0] || null;
    }

    async function loadDetail(id){
      artEl.innerHTML = 'Loading…'; artEl.classList.add('loader');
      const item = id ? await fetchOne(id) : await fetchLatest();
      if(!item){ artEl.classList.remove('loader'); artEl.innerHTML = '<div class="empty">Not found.</div>'; return; }
      renderArticle(item);
    }

    async function boot(){
      const params = new URLSearchParams(location.search);
      const wanted = params.get('news_id');
      const list = await fetchList(16);
      renderList(list, wanted);
      highlightActive(wanted);
      await loadDetail(wanted);
    }

    window.addEventListener('popstate', () => {
      const params = new URLSearchParams(location.search);
      const id = params.get('news_id');
      highlightActive(id);
      loadDetail(id);
    });

    boot().catch(err=>{
      console.error(err);
      artEl.classList.remove('loader');
      artEl.innerHTML = '<div class="empty">Failed to load news.</div>';
    });
  </script>
</body>
</html>
