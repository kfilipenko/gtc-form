      async function hydrateUserFromProfile(fallbackUser = null) {
        try {
          const resp = await fetch('/auth/profile', { credentials: 'include' });
          if (resp.ok) {
            const data = await resp.json().catch(() => null);
            if (data?.gtc_user_id) {
              saveUser({
                email: data.email || fallbackUser?.email || state.user?.email || null,
                id: data.id || data.user_id || fallbackUser?.id || state.user?.id || null,
                gtc_user_id: data.gtc_user_id,
                full_name: data.full_name || data.name || fallbackUser?.full_name || state.user?.full_name || null
              });
              return { ok: true, source: 'profile' };
            }
          }
        } catch (error) {
          console.warn('profile fetch failed', error);
        }
        if (fallbackUser?.gtc_user_id) {
          saveUser(fallbackUser);
          return { ok: true, source: 'fallback' };
        }
        return { ok: false };
      }

      async function syncAuthStatus(context = 'manual') {
        try {
          const resp = await fetch('/auth/status', { credentials: 'include' });
          if (!resp.ok) {
            const err = new Error('status_http_' + resp.status);
            err.status = resp.status;
            err.statusText = resp.statusText;
            try { err.body = await resp.text(); } catch {}
            throw err;
          }
          const data = await resp.json().catch(() => null);
          if (!data) {
            const err = new Error('status_bad_json');
            err.status = resp.status;
            throw err;
          }
          applyStatusDecision(data, context);
          return { ok: true, data };
        } catch (error) {
          console.warn('auth status error', error);
          return { ok: false, error };
        }
      }

      function describeStatusError(error) {
        if (!error) return 'Status service unavailable. Please retry in a moment.';
        if (error.status === 401) return 'Session expired. Please sign in again.';
        if (error.status === 403) return 'Email is not verified yet. Complete verification first.';
        if (error.status === 404) return '/auth/status is not deployed yet.';
        if (error.message === 'status_bad_json') return 'Status service returned malformed JSON.';
        if (error.name === 'TypeError') return 'Unable to reach /auth/status (check network).';
        return `Status service unavailable (code ${error.status || error.message || 'unknown'}).`;
      }

      function applyStatusDecision(data, context = 'manual') {
        if (!data) return;
        if (data.gtc_user_id) {
          saveUser({
            email: data.email || state.user?.email || null,
            id: data.id || data.user_id || state.user?.id || null,
            gtc_user_id: data.gtc_user_id,
            full_name: data.full_name || state.user?.full_name || null
          }, '');
        }
        const decision = deduceDecision(data);
        if (decision === 'payment') {
          handlePaymentRequired(data, context);
          return;
        }
        if (decision === 'chat') {
          setChatStatus('Access confirmed.', 'ok');
          pushSystem('Authorization completed.', 'ok');
          if (paymentPanel) paymentPanel.hidden = true;
          return;
        }
        if (decision === 'auth') {
          setChatStatus('Sign-in required.', 'warn');
          pushSystem('Session not found. Please authenticate again.', 'warn');
          if (paymentPanel) paymentPanel.hidden = true;
        }
      }

      function deduceDecision(data) {
        if (!data) return null;
        if (data.decision) return data.decision;
        if (data.status === 'payment_required') return 'payment';
        if (data.status === 'ok') return 'chat';
        if (data.status === 'unauthorized') return 'auth';
        const redirect = data.redirect || data.next;
        if (typeof redirect === 'string') {
          if (redirect.includes('payment')) return 'payment';
          if (redirect.includes('/chat')) return 'chat';
        }
        return null;
      }

      function handlePaymentRequired(data, context = 'manual') {
        const paymentUrl = data?.payment_url || PAYMENT_URL;
        const msg = paymentUrl ? `Subscription required. Open ${paymentUrl}, complete the payment, then return to chat.` : 'Subscription required. Open the billing portal and retry.';
        pushSystem(msg, 'warn');
        setChatStatus('Subscription inactive. Complete payment and retry.', 'warn');
        if (paymentPanel) {
          paymentPanel.hidden = false;
          paymentPanel.dataset.critical = context === 'manual' ? 'false' : 'true';
        }
        if (paymentMessage) paymentMessage.textContent = msg;
        openAccordionSection('account');
      }

