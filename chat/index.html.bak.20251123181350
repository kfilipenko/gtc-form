        if (result.ok) {
          setChatStatus('Profile refreshed.', 'ok');
        } else {
          setChatStatus('Profile refresh failed.', 'err');
        }
      });

      resetSessionBtn.addEventListener('click', () => {
        resetSession();
      });

      clearChatBtn.addEventListener('click', () => {
        clearHistory();
        pushSystem('Local history cleared.');
      });

      chatForm.addEventListener('submit', async (event) => {
        event.preventDefault();
        if (!state.user?.gtc_user_id) {
          setChatStatus('Sign in first to obtain a gtc_user_id.', 'warn');
          return;
        }
        const message = chatInput.value.trim();
        if (!message) return;
        await sendMessage(message);
      });

      chatInput.addEventListener('keydown', (event) => {
        if (event.key === 'Enter' && !event.shiftKey) {
          event.preventDefault();
          chatForm.dispatchEvent(new Event('submit'));
        }
      });

      window.addEventListener('load', bootGoogle);

      async function sendMessage(text) {
        if (state.sending) return;
        state.sending = true;
        sendBtn.disabled = true;
        sendBtn.textContent = 'Sending...';
        setChatStatus('Sending request to n8n...', 'warn');
        pushMessage('user', text, {});
        chatInput.value = '';
        try {
          const payload = buildPayload(text);
          const response = await fetch('https://agent.gtstor.com/webhook/chat', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
          });
          const data = await response.json().catch(() => ({ status: 'error', detail: 'bad_json' }));
          handleAgentResponse(data, response.status);
        } catch (error) {
          pushSystem('Network error: ' + error.message, 'err');
          setChatStatus('Network error.', 'err');
        } finally {
          state.sending = false;
          sendBtn.disabled = false;
          sendBtn.textContent = 'Send';
        }
      }

      function buildPayload(message) {
        const timezone = Intl.DateTimeFormat().resolvedOptions().timeZone;
        const locale = navigator.language || 'en';
        return {
          channel: 'web',
          message,
          session_id: state.sessionId,
          client: {
            gtc_user_id: state.user?.gtc_user_id ?? null,
            user_id: state.user?.id ?? null,
            email: state.user?.email ?? null,
            locale,
            timezone,
            metadata: {
              full_name: state.user?.full_name || null
            }
          },
          metadata: {
            page: location.pathname,
            user_agent: navigator.userAgent,
            language: locale
          }
        };
      }

      function handleAgentResponse(data, httpStatus) {
        if (httpStatus === 401 || data?.status === 'error' && data?.code === 'unauthorized') {
          pushSystem('Access denied. Please complete payment or sign in again.', 'err');
          setChatStatus('Unauthorized. Please sign in again.', 'err');
          state.user = null;
          localStorage.removeItem(storageKeys.user);
          updateAuthUI();
          return;
        }
        if (httpStatus === 402 || data?.status === 'payment_required') {
          pushSystem('Subscription required. Use your gtc_user_id inside the billing portal.', 'warn');
          setChatStatus('Subscription inactive. Complete payment and retry.', 'warn');
          return;
        }
        if (httpStatus >= 500 || data?.status === 'error') {
          setChatStatus('Server error, please retry later.', 'err');
          return;
        }
        const reply = data?.reply || data?.output || 'No response';
        pushMessage('bot', reply, { trace_id: data?.trace_id, stage: data?.stage });
        setChatStatus('Done (trace ' + (data?.trace_id || '—') + ')', 'ok');
      }
    })();
  </script>
</body>
</html>
