<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>GTC • Web Chat</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta http-equiv="Cache-Control" content="no-store" />
  <link rel="icon" href="/favicon.ico" />
  <style>
    :root {
      color-scheme: dark;
      --bg: #060912;
      --panel: #0f1625;
      --panel-soft: rgba(255,255,255,0.02);
      --border: #1f2a44;
      --accent: #68b5ff;
      --muted: #9ba6bf;
      --danger: #ff7b7b;
      --success: #7be0c3;
      --warning: #f7c873;
    }

    * { box-sizing: border-box; }
    html, body {
      margin: 0;
      height: 100%;
      font-family: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background: var(--bg);
      color: #e6eefc;
    }
    body { display: flex; min-height: 100vh; }

    .layout {
      flex: 1;
      display: grid;
      grid-template-columns: minmax(300px, 380px) 1fr;
      max-width: 1440px;
      margin: 0 auto;
      width: 100%;
    }

    aside {
      background: var(--panel);
      border-right: 1px solid var(--border);
      padding: 28px 22px 32px;
      display: flex;
      flex-direction: column;
      gap: 18px;
    }

    main { display: flex; flex-direction: column; height: 100vh; }

    @media (max-width: 960px) {
      .layout { grid-template-columns: 1fr; }
      aside { border-right: none; border-bottom: 1px solid var(--border); }
      main { height: auto; min-height: calc(100vh - 240px); }
    }

    h1 { margin: 0; font-size: 1.35rem; }
    .subtitle { font-size: 0.9rem; color: var(--muted); margin: 0; }

    label { display: block; margin-bottom: 6px; font-size: 0.9rem; }
    input, textarea, button { font-family: inherit; font-size: 1rem; }
    input, textarea {
      width: 100%;
      padding: 12px 14px;
      border-radius: 12px;
      border: 1px solid rgba(255,255,255,0.08);
      background: rgba(255,255,255,0.04);
      color: #fff;
    }
    input:focus, textarea:focus { outline: none; border-color: var(--accent); }
    textarea { min-height: 90px; resize: vertical; }

    button {
      cursor: pointer;
      border: none;
      border-radius: 12px;
      padding: 12px 16px;
      font-weight: 600;
      transition: opacity 0.2s ease;
    }
    button:disabled { opacity: 0.65; cursor: not-allowed; }
    .btn-primary { background: linear-gradient(120deg, #2d7dff, #68b5ff); color: #051021; }
    .btn-secondary { background: rgba(255,255,255,0.08); color: #fff; border: 1px solid rgba(255,255,255,0.15); }
    .btn-danger { background: rgba(255,91,91,0.18); color: var(--danger); border: 1px solid rgba(255,91,91,0.5); }

    .stack { display: flex; flex-direction: column; gap: 12px; }
    .row { display: flex; gap: 12px; align-items: center; }
    .row.wrap { flex-wrap: wrap; }

    .hint { font-size: 0.82rem; color: var(--muted); }
    .status { font-size: 0.9rem; border-radius: 10px; padding: 8px 12px; margin-top: 6px; background: rgba(255,255,255,0.04); color: #fff; }
    .status.ok { background: rgba(123,224,195,0.16); color: var(--success); }
    .status.err { background: rgba(255,123,123,0.16); color: var(--danger); }
    .status.warn { background: rgba(247,200,115,0.16); color: var(--warning); }

    .pill {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      border-radius: 999px;
      padding: 4px 10px;
      font-size: 0.85rem;
      border: 1px solid rgba(255,255,255,0.15);
    }
    .pill small { color: var(--muted); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.1em; }

    .sidebar-header { display: flex; flex-direction: column; gap: 4px; }
    .accordion { display: flex; flex-direction: column; gap: 12px; }
    .accordion-item { border: 1px solid var(--border); border-radius: 16px; background: var(--panel-soft); overflow: hidden; }
    .accordion-header {
      width: 100%;
      background: none;
      border: none;
      color: inherit;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 14px 18px;
      font-size: 0.95rem;
      cursor: pointer;
      text-align: left;
    }
    .accordion-title { font-weight: 600; display: block; }
    .accordion-subtitle { font-size: 0.78rem; color: var(--muted); display: block; }
    .accordion-icon { font-size: 1rem; color: var(--muted); transition: transform 0.2s ease; }
    .accordion-item[data-open="true"] .accordion-icon { transform: rotate(90deg); }
    .accordion-body { display: none; padding: 0 18px 18px; }
    .accordion-item[data-open="true"] .accordion-body { display: flex; flex-direction: column; gap: 12px; }

    .sidebar-block {
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 12px;
      padding: 14px 16px;
      background: rgba(4,8,16,0.4);
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
    .sidebar-block form { margin: 0; }
    .section-label { font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.12em; color: var(--muted); }

    .payment-panel { border: 1px solid rgba(247,200,115,0.6); background: rgba(247,200,115,0.08); }
    .payment-panel[data-critical="true"] { border-color: rgba(255,123,123,0.7); background: rgba(255,123,123,0.12); }

    .link { color: var(--accent); text-decoration: none; }
    .link:hover { text-decoration: underline; }
    .divider { height: 1px; background: rgba(255,255,255,0.08); margin: 6px 0; }
    .badge { font-size: 0.75rem; padding: 2px 8px; border-radius: 999px; border: 1px solid rgba(255,255,255,0.15); }
    .text-button { background: none; border: none; color: var(--accent); cursor: pointer; font: inherit; padding: 0; }
    .text-button:hover { text-decoration: underline; }
    .subtle-panel { border: 1px dashed rgba(255,255,255,0.2); border-radius: 14px; padding: 14px; background: rgba(255,255,255,0.02); margin-top: 6px; }

    .chat-pane { flex: 1; display: flex; flex-direction: column; padding: 28px; gap: 16px; }
    .chat-header { display: flex; flex-wrap: wrap; gap: 12px; align-items: center; justify-content: space-between; }
    .chat-log {
      flex: 1;
      overflow-y: auto;
      border: 1px solid var(--border);
      border-radius: 20px;
      padding: 20px;
      background: rgba(4,8,16,0.55);
      display: flex;
      flex-direction: column;
      gap: 14px;
    }
    .chat-msg {
      border-radius: 14px;
      padding: 12px 14px;
      max-width: 90%;
      line-height: 1.5;
      white-space: pre-wrap;
      word-break: break-word;
    }
    .chat-msg.user { margin-left: auto; background: rgba(104,181,255,0.12); border: 1px solid rgba(104,181,255,0.4); }
    .chat-msg.bot { background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.08); }
    .chat-msg.system { background: rgba(255,123,123,0.12); border: 1px dashed rgba(255,123,123,0.45); font-size: 0.9rem; }
    .msg-meta { font-size: 0.8rem; color: var(--muted); margin-top: 6px; }

    .chat-form { display: flex; flex-direction: column; gap: 10px; }
    .chat-form .row { align-items: stretch; }
    .tagline { font-size: 0.85rem; color: var(--muted); }

    .tech-panel {
      border-radius: 16px;
      border: 1px solid var(--border);
      background: rgba(255,255,255,0.02);
      padding: 14px 16px;
      min-height: 48px;
      display: flex;
      align-items: center;
      font-size: 0.95rem;
      color: var(--muted);
      transition: border-color 0.2s ease, color 0.2s ease, background 0.2s ease;
    }
    .tech-panel[data-tone="ok"] { border-color: rgba(123,224,195,0.5); color: var(--success); background: rgba(123,224,195,0.08); }
    .tech-panel[data-tone="warn"] { border-color: rgba(247,200,115,0.5); color: var(--warning); }
    .tech-panel[data-tone="err"] { border-color: rgba(255,123,123,0.5); color: var(--danger); }
  </style>
</head>
<body>
  <div class="layout">
    <aside>
      <div class="sidebar-header">
        <h1>GTC Web Chat</h1>
        <p class="subtitle">Single-page onboarding for registration, auth, and billing.</p>
      </div>

      <div class="accordion" id="sidebarAccordion">
        <section class="accordion-item" data-section="registration" data-open="false">
          <button class="accordion-header" type="button" aria-expanded="false">
            <div>
              <span class="accordion-title">Registration</span>
              <span class="accordion-subtitle">Create an account or resend email</span>
            </div>
            <span class="accordion-icon" aria-hidden="true">›</span>
          </button>
          <div class="accordion-body">
            <div id="signupSection" class="sidebar-block stack">
              <div class="section-label">New account</div>
              <form id="signupForm" class="stack" autocomplete="off">
                <div>
                  <label for="signupName">Name</label>
                  <input id="signupName" type="text" placeholder="John" minlength="2" />
                </div>
                <div>
                  <label for="signupEmail">Work email</label>
                  <input id="signupEmail" type="email" placeholder="you@example.com" required />
                </div>
                <div>
                  <label for="signupPassword">Password</label>
                  <input id="signupPassword" type="password" placeholder="Min 8 chars, 1 uppercase" minlength="8" required autocomplete="new-password" />
                </div>
                <button id="signupSubmit" class="btn-primary" type="submit">Create account</button>
                <div class="hint">After confirming the email, return to “Authorization” and press “Check access”.</div>
              </form>
              <div id="signupStatus" class="status" hidden></div>
            </div>

            <div class="sidebar-block stack">
              <div class="section-label">Resend verification</div>
              <form id="resendForm" class="stack" autocomplete="off">
                <div>
                  <label for="resendEmail">Email to resend</label>
                  <input id="resendEmail" type="email" placeholder="you@example.com" required />
                </div>
                <button id="resendSubmit" class="btn-secondary" type="submit">Send email again</button>
              </form>
              <div id="resendStatus" class="status" hidden></div>
              <div class="hint">We show the exact response from the auth service so you know if the message was queued.</div>
            </div>
          </div>
        </section>

        <section class="accordion-item" data-section="authorization" data-open="false">
          <button class="accordion-header" type="button" aria-expanded="false">
            <div>
              <span class="accordion-title">Authorization</span>
              <span class="accordion-subtitle">Email + password, Google, OTP</span>
            </div>
            <span class="accordion-icon" aria-hidden="true">›</span>
          </button>
          <div class="accordion-body">
            <div id="authSection" class="sidebar-block stack">
              <div class="section-label">Email & password</div>
              <form id="authForm" class="stack" autocomplete="on">
                <div>
                  <label for="authEmail">Email</label>
                  <input id="authEmail" type="email" placeholder="you@example.com" required />
                </div>
                <div>
                  <label for="authPassword">Password</label>
                  <input id="authPassword" type="password" placeholder="••••••••" required autocomplete="current-password" />
                </div>
                <button id="authSubmit" class="btn-primary" type="submit">Sign in & fetch gtc_user_id</button>
                <button id="accessCheckBtn" class="btn-secondary" type="button">Check workspace access</button>
                <div class="hint">Use the same email you employ inside GTC. We will store the user record locally for chat.</div>
                <div class="hint">No email yet? <button id="openResendShortcut" type="button" class="text-button">Request the access link</button></div>
                <div class="hint">Forgot your password? <button id="forgotPasswordToggle" type="button" class="text-button">Send a reset link</button></div>
              </form>
              <div id="authStatus" class="status" hidden></div>
              <div id="forgotPasswordPanel" class="subtle-panel stack" hidden>
                <form id="passwordResetFormAuth" class="stack" autocomplete="off">
                  <div>
                    <label for="passwordResetEmailAuth">Email for password reset</label>
                    <input id="passwordResetEmailAuth" type="email" placeholder="you@example.com" required />
                  </div>
                  <button id="passwordResetSubmitAuth" class="btn-secondary" type="submit">Send password reset</button>
                </form>
                <div id="passwordResetStatusAuth" class="status" hidden></div>
                <div class="hint">We email a secure 60-minute link to /auth/password/reset.</div>
              </div>
            </div>

            <div id="quickAuthSection" class="sidebar-block stack">
              <div class="section-label">Google / OTP</div>
              <p class="hint">Faster flows without typing your password.</p>
              <div id="googleBtnHost" style="min-height:46px"></div>
              <button id="googleFallbackBtn" class="btn-secondary" type="button" hidden>Open Google fallback</button>
              <div class="divider"></div>
              <div class="stack" style="gap:10px">
                <div>
                  <label for="otpEmail">Email for OTP</label>
                  <input id="otpEmail" type="email" placeholder="you@example.com" />
                </div>
                <div class="row wrap" style="gap:10px">
                  <button id="otpRequestBtn" class="btn-secondary" type="button">Get code</button>
                  <button id="otpVerifyBtn" class="btn-primary" type="button" disabled>Verify code</button>
                </div>
                <div>
                  <label for="otpCode">Code from email</label>
                  <input id="otpCode" type="text" placeholder="123456" inputmode="numeric" pattern="[0-9]{4,6}" maxlength="6" disabled />
                </div>
                <div class="hint">Codes stay valid for 10 minutes. We reset attempts after each success.</div>
                <div id="otpStatus" class="status" hidden></div>
              </div>
            </div>
          </div>
        </section>

        <section class="accordion-item" data-section="account" data-open="false">
          <button class="accordion-header" type="button" aria-expanded="false">
            <div>
              <span class="accordion-title">Account management</span>
              <span class="accordion-subtitle">Sessions, profile, billing</span>
            </div>
            <span class="accordion-icon" aria-hidden="true">›</span>
          </button>
          <div class="accordion-body">
            <div id="userSection" class="sidebar-block stack" hidden>
              <div class="section-label">Current session</div>
              <div class="row" style="justify-content: space-between; align-items: center; gap:10px;">
                <div>
                  <div class="hint" style="text-transform:uppercase;letter-spacing:.2em;font-size:.72rem">Your code</div>
                  <div class="user-id" id="userIdDisplay">—</div>
                </div>
                <button id="copyIdBtn" class="btn-secondary" type="button">Copy</button>
              </div>
              <div class="stack" style="gap:8px">
                <div><span class="hint">Email:</span> <span id="userEmail">—</span></div>
                <div class="divider"></div>
                <div class="hint">Session: <span id="sessionDisplay"></span></div>
                <div class="row wrap" style="gap:8px;">
                  <button id="resetSession" class="btn-secondary" type="button">New chat session</button>
                  <button id="clearChat" class="btn-secondary" type="button">Clear history</button>
                </div>
                <div class="row wrap" style="gap:8px;">
                  <button id="refreshProfile" class="btn-secondary" type="button">Refresh profile</button>
                  <button id="logoutBtn" class="btn-danger" type="button" hidden>Sign out</button>
                </div>
              </div>
            </div>

            <div class="sidebar-block stack">
              <div class="section-label">Access & password</div>
              <form id="accessLinkForm" class="stack" autocomplete="off">
                <div>
                  <label for="accessLinkEmail">Email for access link</label>
                  <input id="accessLinkEmail" type="email" placeholder="you@example.com" required />
                </div>
                <button id="accessLinkSubmit" class="btn-secondary" type="submit">Send verification link</button>
              </form>
              <div id="accessLinkStatus" class="status" hidden></div>
              <div class="hint">We’ll send the same verification link the signup flow uses.</div>
              <div class="divider"></div>
              <form id="passwordResetForm" class="stack" autocomplete="off">
                <div>
                  <label for="passwordResetEmail">Email to reset password</label>
                  <input id="passwordResetEmail" type="email" placeholder="you@example.com" required />
                </div>
                <button id="passwordResetSubmit" class="btn-secondary" type="submit">Send password reset</button>
              </form>
              <div id="passwordResetStatus" class="status" hidden></div>
              <div class="hint">We email a 60-minute link to /auth/password/reset.</div>
            </div>

            <div id="paymentPanel" class="sidebar-block stack payment-panel" hidden>
              <div class="section-label">Billing</div>
              <p id="paymentMessage">We could not confirm an active subscription. Complete payment to unlock the chat.</p>
              <a class="btn-secondary" href="https://pay.gtstor.com/payment.php" target="_blank" rel="noopener">Open billing portal</a>
            </div>

            <div class="sidebar-block stack">
              <div class="section-label">Knowledge base</div>
              <ul style="margin:0;padding-left:18px;color:#cfd8f5;display:flex;flex-direction:column;gap:6px;font-size:0.85rem;">
                <li>We store history per <code>session_id</code>. Use “New chat session” to start over.</li>
                <li>If access is denied, verify email first, then ensure billing is active.</li>
                <li>Replies come from n8n workflow <strong>GTC Sales Agent - Web Chat</strong>.</li>
              </ul>
            </div>
          </div>
        </section>
      </div>
    </aside>

    <main class="chat-pane">
      <div class="chat-header">
        <div>
          <div class="pill"><small>Status</small> <span id="statusLabel">offline</span></div>
          <div class="tagline" id="stageLabel"></div>
        </div>
        <div class="tagline">Webhook: <code>https://agent.gtstor.com/webhook/chat</code></div>
      </div>

      <div id="chatLog" class="chat-log"></div>
      <div id="techPanel" class="tech-panel" hidden></div>

      <form id="chatForm" class="chat-form">
        <div>
          <label for="chatInput">Enter your message</label>
          <textarea id="chatInput" placeholder="For example: Help me find a solution. I have a task...." required></textarea>
        </div>
        <div class="row" style="justify-content: space-between; gap:12px; flex-wrap: wrap;">
          <div class="tagline">Shift+Enter inserts a line break.</div>
          <div class="row" style="gap:10px;">
            <button id="sendBtn" class="btn-primary" type="submit">Send</button>
          </div>
        </div>
      </form>
      <div id="chatStatus" class="status" hidden></div>
    </main>
  </div>

  <script>
    (() => {
      const GOOGLE_CLIENT_ID = '295337863113-sjl11e4rfttsqgaubfhl9ketv5nv20jc.apps.googleusercontent.com';
      const PAYMENT_URL = 'https://pay.gtstor.com/payment.php';
      const $ = (sel) => document.querySelector(sel);
      const statusLabel = $('#statusLabel');
      const stageLabel = $('#stageLabel');
      const chatLog = $('#chatLog');
      const chatInput = $('#chatInput');
      const chatForm = $('#chatForm');
      const sendBtn = $('#sendBtn');
      const chatStatus = $('#chatStatus');
      const authForm = $('#authForm');
      const authStatus = $('#authStatus');
      const authEmailInput = $('#authEmail');
      const authPasswordInput = $('#authPassword');
      const forgotPasswordToggle = $('#forgotPasswordToggle');
      const forgotPasswordPanel = $('#forgotPasswordPanel');
      const logoutBtn = $('#logoutBtn');
      const userSection = $('#userSection');
      const authSection = $('#authSection');
      const copyIdBtn = $('#copyIdBtn');
      const sessionDisplay = $('#sessionDisplay');
      const clearChatBtn = $('#clearChat');
      const resetSessionBtn = $('#resetSession');
      const refreshProfileBtn = $('#refreshProfile');
      const quickAuthSection = $('#quickAuthSection');
      const googleBtnHost = $('#googleBtnHost');
      const googleFallbackBtn = $('#googleFallbackBtn');
      const otpEmailInput = $('#otpEmail');
      const otpCodeInput = $('#otpCode');
      const otpRequestBtn = $('#otpRequestBtn');
      const otpVerifyBtn = $('#otpVerifyBtn');
      const otpStatus = $('#otpStatus');
      const signupForm = $('#signupForm');
      const signupStatus = $('#signupStatus');
      const signupNameInput = $('#signupName');
      const signupEmailInput = $('#signupEmail');
      const signupPasswordInput = $('#signupPassword');
      const resendForm = $('#resendForm');
      const resendStatus = $('#resendStatus');
      const resendEmailInput = $('#resendEmail');
      const resendShortcutBtn = $('#openResendShortcut');
      const accessLinkForm = $('#accessLinkForm');
      const accessLinkEmailInput = $('#accessLinkEmail');
      const accessLinkStatus = $('#accessLinkStatus');
      const passwordResetForm = $('#passwordResetForm');
      const passwordResetEmailInput = $('#passwordResetEmail');
      const passwordResetStatus = $('#passwordResetStatus');
      const passwordResetFormAuth = $('#passwordResetFormAuth');
      const passwordResetEmailInputAuth = $('#passwordResetEmailAuth');
      const passwordResetStatusAuth = $('#passwordResetStatusAuth');
      const accessCheckBtn = $('#accessCheckBtn');
      const techPanel = $('#techPanel');
      const paymentPanel = $('#paymentPanel');
      const paymentMessage = $('#paymentMessage');
      const accordionRoot = $('#sidebarAccordion');
      const accordionItems = accordionRoot ? Array.from(accordionRoot.querySelectorAll('.accordion-item')) : [];

      const storageKeys = {
        user: 'chat:user',
        session: 'chat:session',
        history: 'chat:history'
      };

      const state = {
        user: loadUser(),
        sending: false,
        sessionId: ensureSession(),
        history: loadHistory(),
        traceId: null
      };
      const otpState = {
        email: '',
        requested: false
      };

      accordionItems.forEach((item) => {
        syncAccordionHeader(item);
        const header = item.querySelector('.accordion-header');
        if (!header) return;
        header.addEventListener('click', () => {
          const next = item.dataset.open !== 'true';
          setAccordionState(item, next);
        });
      });

      resendShortcutBtn?.addEventListener('click', () => {
        openAccordionSection('registration');
        prefillSupportEmails(true);
        if (resendEmailInput) {
          resendEmailInput.focus();
          setTimeout(() => resendEmailInput.select(), 50);
        }
      });

      forgotPasswordToggle?.addEventListener('click', () => {
        if (!forgotPasswordPanel) return;
        const isHidden = forgotPasswordPanel.hidden;
        forgotPasswordPanel.hidden = !isHidden;
        if (!forgotPasswordPanel.hidden) {
          prefillSupportEmails(true);
          passwordResetEmailInputAuth?.focus();
          setTimeout(() => passwordResetEmailInputAuth?.select(), 50);
        }
      });

      function syncAccordionHeader(item) {
        const header = item.querySelector('.accordion-header');
        if (!header) return;
        header.setAttribute('aria-expanded', item.dataset.open === 'true' ? 'true' : 'false');
      }

      function setAccordionState(item, open) {
        if (!item) return;
        item.dataset.open = open ? 'true' : 'false';
        syncAccordionHeader(item);
      }

      function openAccordionSection(name) {
        const item = accordionItems.find((node) => node.dataset.section === name);
        if (item) setAccordionState(item, true);
      }

      sessionDisplay.textContent = state.sessionId;
      prefillSupportEmails();
      renderHistory();
      updateAuthUI();
      updateStatus('offline');

      function loadUser() {
        try {
          const raw = localStorage.getItem(storageKeys.user);
          if (!raw) return null;
          return JSON.parse(raw);
        } catch { return null; }
      }

      function saveUser(user, message) {
        state.user = user;
        if (user?.email) rememberEmail(user.email);
        try {
          localStorage.setItem(storageKeys.user, JSON.stringify(user));
          if (user?.gtc_user_id) {
            localStorage.setItem('gtc_user_id', String(user.gtc_user_id));
          }
        } catch {}
        const greeting = message === undefined ? ('Welcome, ' + (user?.email || '')) : message;
        updateAuthUI(greeting);
        prefillSupportEmails(true);
      }

      function rememberEmail(email) {
        if (!email) return;
        try { localStorage.setItem('email', email); } catch {}
      }

      function recalledEmail() {
        try { return localStorage.getItem('email') || ''; } catch { return ''; }
      }

      function bestKnownEmail() {
        if (state.user?.email) return state.user.email;
        if (authEmailInput?.value) return authEmailInput.value.trim().toLowerCase();
        if (signupEmailInput?.value) return signupEmailInput.value.trim().toLowerCase();
        if (resendEmailInput?.value) return resendEmailInput.value.trim().toLowerCase();
        if (passwordResetEmailInputAuth?.value) return passwordResetEmailInputAuth.value.trim().toLowerCase();
        const stored = recalledEmail();
        if (stored) return stored;
        return '';
      }

      function prefillSupportEmails(force = false) {
        const email = bestKnownEmail();
        if (!email) return;
        if (resendEmailInput && (force || !resendEmailInput.value)) resendEmailInput.value = email;
        if (accessLinkEmailInput && (force || !accessLinkEmailInput.value)) accessLinkEmailInput.value = email;
        if (passwordResetEmailInput && (force || !passwordResetEmailInput.value)) passwordResetEmailInput.value = email;
