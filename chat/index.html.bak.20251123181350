      let googleButtonReady = false;

      function bootGoogle() {
        if (!googleBtnHost) return;
        if (!GOOGLE_CLIENT_ID || GOOGLE_CLIENT_ID.includes('REPLACE')) {
          if (googleFallbackBtn) googleFallbackBtn.hidden = false;
          return;
        }
        if (window.google?.accounts?.id) {
          renderGoogleButton();
          return;
        }
        googleInitTimer = setInterval(() => {
          if (window.google?.accounts?.id) {
            clearInterval(googleInitTimer);
            renderGoogleButton();
          }
        }, 250);
        setTimeout(() => {
          if (googleInitTimer) clearInterval(googleInitTimer);
          if (!googleButtonReady && googleFallbackBtn) googleFallbackBtn.hidden = false;
        }, 10000);
      }

      function renderGoogleButton() {
        if (!googleBtnHost || googleButtonReady) return;
        if (googleInitTimer) {
          clearInterval(googleInitTimer);
          googleInitTimer = null;
        }
        try {
          google.accounts.id.initialize({
            client_id: GOOGLE_CLIENT_ID,
            callback: handleGoogleCredential,
            ux_mode: 'popup'
          });
          google.accounts.id.renderButton(googleBtnHost, {
            theme: 'outline',
            size: 'large',
            shape: 'pill',
            text: 'continue_with',
            locale: navigator.language || 'en'
          });
          googleButtonReady = true;
          if (googleFallbackBtn) googleFallbackBtn.hidden = true;
        } catch (error) {
          console.warn('GIS render failed', error);
          if (googleFallbackBtn) googleFallbackBtn.hidden = false;
        }
      }

      async function handleGoogleCredential(response) {
        if (!response?.credential) {
          setChatStatus('Google did not return a credential. Please try again.', 'err');
          return;
        }
        setChatStatus('Validating Google credential...', 'warn');
        try {
          const result = await postJson('/auth/google', { google_credential: response.credential });
          if (result.error) {
            setChatStatus('Google sign-in rejected: ' + result.error, 'err');
            return;
          }
          const fallbackUser = {
            email: result.email || state.user?.email || null,
            id: result.id || result.user_id || state.user?.id || null,
            gtc_user_id: result.gtc_user_id || result.gtcUserId || null,
            full_name: result.full_name || result.name || state.user?.full_name || null
          };
          await hydrateUserFromProfile(fallbackUser);
          const statusResult = await syncAuthStatus('google-oauth');
          if (!statusResult.ok) {
            setChatStatus('Signed in but status request failed: ' + describeStatusError(statusResult.error), 'warn');
          }
        } catch (error) {
          setChatStatus('Google sign-in error: ' + error.message, 'err');
        }
      }

      function updateAuthUI(message) {
        const user = state.user;
        const loggedIn = !!(user && user.gtc_user_id);
        authSection.hidden = loggedIn;
        userSection.hidden = !loggedIn;
        logoutBtn.hidden = !loggedIn;
        if (quickAuthSection) quickAuthSection.hidden = loggedIn;
        if (loggedIn) {
          $('#userIdDisplay').textContent = user.gtc_user_id || '—';
          $('#userEmail').textContent = user.email || '—';
          updateStatus('ready', 'ok');
          if (message === undefined) {
            setChatStatus('Signed in successfully.', 'ok');
          } else if (message) {
            setChatStatus(message, 'ok');
          }
        } else {
          updateStatus('offline');
          setChatStatus('Sign in to request a gtc_user_id.', 'warn');
          if (paymentPanel) paymentPanel.hidden = true;
        }
        prefillSupportEmails(loggedIn);
      }

      async function postJson(path, body) {
        const response = await fetch(path, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify(body)
        });
        let json = null;
        try { json = await response.json(); } catch (err) { json = { error: 'bad_json' }; }
        json._status = response.status;
        return json;
      }

      async function sendVerificationRequest(email, statusSetter, button) {
        if (!statusSetter) return false;
        if (!email) {
          statusSetter('Enter the email associated with your workspace.', 'err');
          return false;
        }
        rememberEmail(email);
        prefillSupportEmails(true);
        statusSetter('Sending email...', 'warn');
        if (button) button.disabled = true;
        try {
          const resp = await postJson('/auth/request_email_verification', { email });
          if (resp.error) {
            statusSetter('Error: ' + resp.error, 'err');
            return false;
          }
          if (resp.already_verified) {
            statusSetter('Email already verified. Press “Check access”.', 'ok');
          } else if (resp.sent) {
            statusSetter('Verification email sent. Check your inbox and spam folder.', 'ok');
          } else if (resp.not_found) {
            statusSetter('Account not found. Register first or double-check the address.', 'warn');
          } else {
            statusSetter('Request accepted. If nothing arrives, contact support with a timestamp.', 'warn');
          }
          return true;
        } catch (error) {
          statusSetter('Network error: ' + error.message, 'err');
          return false;
        } finally {
          if (button) button.disabled = false;
        }
      }

