      function ensureSession() {
        const existing = localStorage.getItem(storageKeys.session);
        if (existing) return existing;
        const uid = crypto.randomUUID ? crypto.randomUUID() : 'web-' + Date.now();
        localStorage.setItem(storageKeys.session, uid);
        return uid;
      }

      function resetSession() {
        const uid = crypto.randomUUID ? crypto.randomUUID() : 'web-' + Date.now();
