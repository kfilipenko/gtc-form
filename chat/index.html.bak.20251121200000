<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>GTC • Web Chat</title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta http-equiv="Cache-Control" content="no-store" />
  <link rel="icon" href="/favicon.ico" />
  <style>
    :root {
      color-scheme: dark;
      --bg: #060912;
      --panel: #0f1625;
      --border: #1f2a44;
      --accent: #68b5ff;
      --muted: #9ba6bf;
      --danger: #ff7b7b;
      --success: #7be0c3;
      --warning: #f7c873;
    }
    * { box-sizing: border-box; }
    html, body { margin: 0; height: 100%; font-family: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; background: var(--bg); color: #e6eefc; }
    body { display: flex; min-height: 100vh; }
    .layout { flex: 1; display: grid; grid-template-columns: minmax(280px, 360px) 1fr; max-width: 1400px; margin: 0 auto; width: 100%; }
    aside { background: var(--panel); border-right: 1px solid var(--border); padding: 24px 20px 32px; display: flex; flex-direction: column; gap: 20px; }
    main { display: flex; flex-direction: column; height: 100vh; }
    @media (max-width: 900px) {
      .layout { grid-template-columns: 1fr; }
      aside { border-right: none; border-bottom: 1px solid var(--border); }
      main { height: auto; min-height: calc(100vh - 240px); }
    }
    h1 { margin: 0 0 6px; font-size: 1.4rem; }
    .subtitle { font-size: 0.92rem; color: var(--muted); margin-bottom: 10px; }
    .card { background: rgba(255,255,255,0.02); border: 1px solid var(--border); border-radius: 16px; padding: 16px 18px; }
    label { font-size: 0.9rem; display: block; margin-bottom: 6px; }
    input, textarea, button { font-family: inherit; font-size: 1rem; }
    input, textarea { width: 100%; padding: 12px 14px; border-radius: 12px; border: 1px solid rgba(255,255,255,0.08); background: rgba(255,255,255,0.03); color: #fff; }
    input:focus, textarea:focus { outline: none; border-color: var(--accent); }
    button { cursor: pointer; border: none; border-radius: 12px; padding: 12px 16px; font-weight: 600; transition: opacity .2s ease; }
    button:disabled { opacity: .6; cursor: not-allowed; }
    .btn-primary { background: linear-gradient(120deg, #2d7dff, #68b5ff); color: #051021; }
    .btn-secondary { background: rgba(255,255,255,0.08); color: #fff; border: 1px solid rgba(255,255,255,0.12); }
    .btn-danger { background: rgba(255,91,91,0.15); color: var(--danger); border: 1px solid rgba(255,91,91,0.4); }
    .stack { display: flex; flex-direction: column; gap: 12px; }
    .row { display: flex; gap: 12px; align-items: center; }
    .row.wrap { flex-wrap: wrap; }
    .hint { font-size: 0.85rem; color: var(--muted); }
    .status { font-size: 0.9rem; border-radius: 10px; padding: 8px 12px; margin-top: 6px; }
    .status.ok { background: rgba(123,224,195,0.16); color: var(--success); }
    .status.err { background: rgba(255,123,123,0.16); color: var(--danger); }
    .status.warn { background: rgba(247,200,115,0.16); color: var(--warning); }
    .user-id { font-size: 1.8rem; font-weight: 700; letter-spacing: 0.05em; }
    .pill { display: inline-flex; align-items: center; gap: 6px; border-radius: 999px; padding: 4px 10px; font-size: 0.85rem; border: 1px solid rgba(255,255,255,0.15); }
    .pill small { color: var(--muted); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.1em; }

    .chat-pane { flex: 1; display: flex; flex-direction: column; padding: 28px; gap: 16px; }
    .chat-header { display: flex; flex-wrap: wrap; gap: 12px; align-items: center; justify-content: space-between; }
    .chat-log { flex: 1; overflow-y: auto; border: 1px solid var(--border); border-radius: 20px; padding: 20px; background: rgba(4,8,16,0.55); display: flex; flex-direction: column; gap: 14px; }
    .chat-msg { border-radius: 14px; padding: 12px 14px; max-width: 90%; line-height: 1.5; white-space: pre-wrap; word-break: break-word; }
    .chat-msg.user { margin-left: auto; background: rgba(104,181,255,0.12); border: 1px solid rgba(104,181,255,0.4); }
    .chat-msg.bot { background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.08); }
    .chat-msg.system { background: rgba(255,123,123,0.12); border: 1px dashed rgba(255,123,123,0.45); font-size: 0.9rem; }
    .msg-meta { font-size: 0.8rem; color: var(--muted); margin-top: 6px; }
    .chat-form { display: flex; flex-direction: column; gap: 10px; }
    .chat-form .row { align-items: stretch; }
    .chat-form textarea { min-height: 90px; resize: vertical; }
    .tagline { font-size: 0.85rem; color: var(--muted); }
    .link { color: var(--accent); text-decoration: none; }
    .link:hover { text-decoration: underline; }
    .divider { height: 1px; background: rgba(255,255,255,0.06); margin: 12px 0; }
    .badge { font-size: 0.75rem; padding: 2px 8px; border-radius: 999px; border: 1px solid rgba(255,255,255,0.15); }
  </style>
</head>
<body>
  <div class="layout">
    <aside>
      <div>
        <h1>GTC Web Chat</h1>
      </div>

      <section id="userSection" class="card stack" hidden>
        <div class="row" style="justify-content: space-between; align-items: center; gap:10px;">
          <div>
            <div class="hint" style="text-transform:uppercase;letter-spacing:.2em;font-size:.72rem">Ваш код</div>
            <div class="user-id" id="userIdDisplay">—</div>
          </div>
          <button id="copyIdBtn" class="btn-secondary" type="button">Скопировать</button>
        </div>
        <div class="stack" style="gap:8px">
          <div><span class="hint">Email:</span> <span id="userEmail">—</span></div>
          <div class="divider"></div>
          <div class="hint">Session: <span id="sessionDisplay"></span></div>
          <div class="row wrap" style="gap:8px;">
            <button id="resetSession" class="btn-secondary" type="button">New chat</button>
          </div>
          <div class="row wrap" style="gap:8px;">
            <button id="refreshProfile" class="btn-secondary" type="button">Обновить профиль</button>
            <a class="btn-secondary" href="https://pay.gtstor.com/payment.php" target="_blank" rel="noopener">Оплатить подписку</a>
          </div>
        </div>
      </section>



<section id="authSection" class="card stack">
        <div class="row wrap" style="justify-content: space-between; align-items: flex-start;">
          <div>
            <h2 style="margin:0;font-size:1.05rem">Авторизация</h2>
            <p class="hint" style="margin-top:4px">Введите email и пароль, используемые в GTC.</p>
          </div>
          <button id="logoutBtn" class="btn-danger" type="button" hidden>Выйти</button>
        </div>

        <form id="authForm" class="stack" autocomplete="on">
          <div>
            <label for="authEmail">Email</label>
            <input id="authEmail" type="email" placeholder="you@example.com" required />
          </div>
          <div>
            <label for="authPassword">Пароль</label>
            <input id="authPassword" type="password" placeholder="••••••••" required autocomplete="current-password" />
          </div>
          <button id="authSubmit" class="btn-primary" type="submit">Войти и получить gtc_user_id</button>
          <div class="hint">Нет аккаунта? <a class="link" href="/auth/email/?next=%2Fchat">Зарегистрируйтесь по email</a> или продолжите через <a class="link" href="/auth/google/?next=%2Fchat">Google</a>.</div>
        </form>
        <div id="authStatus" class="status" hidden></div>
      </section>

      <section id="quickAuthSection" class="card stack">
        <div>
          <h2 style="margin:0;font-size:1.05rem">OAuth / OTP</h2>
          <p class="hint" style="margin-top:4px">Быстрый вход без пароля.</p>
        </div>
        <button id="googleBtn" class="btn-secondary" type="button">Продолжить через Google</button>

        <div class="divider"></div>
        <div class="stack" style="gap:10px">
          <div>
            <label for="otpEmail">Email для OTP</label>
            <input id="otpEmail" type="email" placeholder="you@example.com" />
          </div>
          <div class="row wrap" style="gap:10px">
            <button id="otpRequestBtn" class="btn-secondary" type="button">Получить код</button>
            <button id="otpVerifyBtn" class="btn-primary" type="button" disabled>Подтвердить</button>
          </div>
          <div>
            <label for="otpCode">Код из email</label>
            <input id="otpCode" type="text" placeholder="123456" inputmode="numeric" pattern="[0-9]{4,6}" maxlength="6" disabled />
          </div>
          <div class="hint">Мы отправим одноразовый код на указанный адрес. Ссылка действует 10 минут.</div>
          <div id="otpStatus" class="status" hidden></div>
        </div>
      </section>

            <section class="card stack">
        <div class="hint">FAQ</div>
        <ul style="margin:0;padding-left:20px;color:#cfd8f5;font-size:0.9rem;display:flex;flex-direction:column;gap:8px">
          <li>Сохраняем историю по <code>session_id</code> (можно сменить через «New chat»).</li>
          <li>При ошибках доступа проверьте активную подписку или обратитесь в поддержку.</li>
          <li>Ответы приходят от n8n workflow <strong>GTC Sales Agent - Web Chat</strong>.</li>
        </ul>
        <div class="row wrap" style="gap:8px;margin-top:10px">
          <button id="clearChat" class="btn-secondary" type="button">Очистить чат</button>
        </div>
      </section>
    </aside>

    <main class="chat-pane">
      <div class="chat-header">
        <div>
          <div class="pill"><small>Status</small> <span id="statusLabel">offline</span></div>
          <div class="tagline" id="stageLabel">Сначала авторизуйтесь, чтобы начать чат.</div>
        </div>
        <div class="tagline">Webhook: <code>/webhook/web-chat</code></div>
      </div>

      <div id="chatLog" class="chat-log"></div>

      <form id="chatForm" class="chat-form">
        <div>
          <label for="chatInput">Сообщение</label>
          <textarea id="chatInput" placeholder="Например: Подбери ноутбук для дизайнера…" required></textarea>
        </div>
        <div class="row" style="justify-content: space-between; gap:12px; flex-wrap: wrap;">
          <div class="tagline">Shift+Enter для переноса строки. Сообщения привязаны к активной сессии.</div>
          <div class="row" style="gap:10px;">
            <button id="sendBtn" class="btn-primary" type="submit">Отправить</button>
          </div>
        </div>
      </form>
      <div id="chatStatus" class="status" hidden></div>
    </main>
  </div>

  <script>
    (() => {
      const $ = (sel) => document.querySelector(sel);
      const statusLabel = $('#statusLabel');
      const stageLabel = $('#stageLabel');
      const chatLog = $('#chatLog');
      const chatInput = $('#chatInput');
      const chatForm = $('#chatForm');
      const sendBtn = $('#sendBtn');
      const chatStatus = $('#chatStatus');
      const authForm = $('#authForm');
      const authStatus = $('#authStatus');
      const logoutBtn = $('#logoutBtn');
      const userSection = $('#userSection');
      const authSection = $('#authSection');
      const copyIdBtn = $('#copyIdBtn');
      const sessionDisplay = $('#sessionDisplay');
      const clearChatBtn = $('#clearChat');
      const resetSessionBtn = $('#resetSession');
      const refreshProfileBtn = $('#refreshProfile');
      const quickAuthSection = $('#quickAuthSection');
      const googleBtn = $('#googleBtn');
      const otpEmailInput = $('#otpEmail');
      const otpCodeInput = $('#otpCode');
      const otpRequestBtn = $('#otpRequestBtn');
      const otpVerifyBtn = $('#otpVerifyBtn');
      const otpStatus = $('#otpStatus');

      const storageKeys = {
        user: 'chat:user',
        session: 'chat:session',
        history: 'chat:history'
      };

      const state = {
        user: loadUser(),
        sending: false,
        sessionId: ensureSession(),
        history: loadHistory(),
        traceId: null
      };
      const otpState = {
        email: '',
        requested: false
      };

      sessionDisplay.textContent = state.sessionId;
      renderHistory();
      updateAuthUI();
      updateStatus('offline');

      function loadUser() {
        try {
          const raw = localStorage.getItem(storageKeys.user);
          if (!raw) return null;
          return JSON.parse(raw);
        } catch { return null; }
      }

      function saveUser(user) {
        state.user = user;
        try {
          localStorage.setItem(storageKeys.user, JSON.stringify(user));
          if (user?.gtc_user_id) {
            localStorage.setItem('gtc_user_id', String(user.gtc_user_id));
          }
        } catch {}
        updateAuthUI('Добро пожаловать, ' + (user?.email || ''));
      }

      function ensureSession() {
        const existing = localStorage.getItem(storageKeys.session);
        if (existing) return existing;
        const uid = crypto.randomUUID ? crypto.randomUUID() : 'web-' + Date.now();
        localStorage.setItem(storageKeys.session, uid);
        return uid;
      }

      function resetSession() {
        const uid = crypto.randomUUID ? crypto.randomUUID() : 'web-' + Date.now();
        localStorage.setItem(storageKeys.session, uid);
        state.sessionId = uid;
        sessionDisplay.textContent = uid;
        pushSystem('Session reset. История на сервере начнёт новую связку.');
      }

      function loadHistory() {
        try {
          const raw = localStorage.getItem(storageKeys.history);
          if (!raw) return [];
          return JSON.parse(raw);
        } catch { return []; }
      }

      function persistHistory() {
        try {
          localStorage.setItem(storageKeys.history, JSON.stringify(state.history.slice(-50)));
        } catch {}
      }

      function clearHistory() {
        state.history = [];
        persistHistory();
        renderHistory();
      }

      function pushMessage(role, text, meta = {}) {
        const entry = { role, text, meta, ts: new Date().toISOString() };
        state.history.push(entry);
        persistHistory();
        appendMessage(entry);
      }

      function pushSystem(text) {
        pushMessage('system', text, {});
      }

      function appendMessage(entry) {
        const div = document.createElement('div');
        div.className = `chat-msg ${entry.role}`;
        div.textContent = entry.text;
        if (entry.meta?.trace_id || entry.meta?.stage) {
          const meta = document.createElement('div');
          meta.className = 'msg-meta';
          const parts = [];
          if (entry.meta.stage) parts.push('Stage: ' + entry.meta.stage);
          if (entry.meta.trace_id) parts.push('Trace: ' + entry.meta.trace_id);
          meta.textContent = parts.join(' · ');
          div.appendChild(meta);
        }
        chatLog.appendChild(div);
        chatLog.scrollTop = chatLog.scrollHeight;
      }

      function renderHistory() {
        chatLog.innerHTML = '';
        state.history.forEach(appendMessage);
      }

      function updateStatus(label, tone = 'warn') {
        statusLabel.textContent = label;
        if (tone === 'ok') {
          statusLabel.style.color = varColor('--success');
        } else if (tone === 'err') {
          statusLabel.style.color = varColor('--danger');
        } else {
          statusLabel.style.color = varColor('--muted');
        }
      }

      function varColor(name) {
        return getComputedStyle(document.documentElement).getPropertyValue(name) || '#cfd8f5';
      }

      function setChatStatus(text, variant = 'warn') {
        if (!text) {
          chatStatus.hidden = true;
          return;
        }
        chatStatus.hidden = false;
        chatStatus.textContent = text;
        chatStatus.className = `status ${variant}`;
      }

      function setAuthStatus(text, variant = 'err') {
        if (!text) {
          authStatus.hidden = true;
          return;
        }
        authStatus.hidden = false;
        authStatus.textContent = text;
        authStatus.className = `status ${variant}`;
      }

      function setOtpStatus(text, variant = 'warn') {
        if (!otpStatus) return;
        if (!text) {
          otpStatus.hidden = true;
          return;
        }
        otpStatus.hidden = false;
        otpStatus.textContent = text;
        otpStatus.className = `status ${variant}`;
      }

      function updateAuthUI(message) {
        const user = state.user;
        const loggedIn = !!(user && user.gtc_user_id);
        authSection.hidden = loggedIn;
        userSection.hidden = !loggedIn;
        logoutBtn.hidden = !loggedIn;
        if (quickAuthSection) quickAuthSection.hidden = loggedIn;
        if (loggedIn) {
          $('#userIdDisplay').textContent = user.gtc_user_id || '—';
          $('#userEmail').textContent = user.email || '—';
          stageLabel.textContent = 'Готов к диалогу. Введите сообщение ниже.';
          updateStatus('ready', 'ok');
          if (message) setChatStatus(message, 'ok'); else setChatStatus('Успешно авторизованы.', 'ok');
        } else {
          stageLabel.textContent = 'Сначала авторизуйтесь, чтобы начать чат.';
          updateStatus('offline');
          setChatStatus('Необходима авторизация для получения gtc_user_id.', 'warn');
        }
      }

      async function postJson(path, body) {
        const response = await fetch(path, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify(body)
        });
        let json = null;
        try { json = await response.json(); } catch (err) { json = { error: 'bad_json' }; }
        json._status = response.status;
        return json;
      }

      authForm.addEventListener('submit', async (event) => {
        event.preventDefault();
        setAuthStatus('');
        const email = $('#authEmail').value.trim().toLowerCase();
        const password = $('#authPassword').value;
        if (!email || !password) {
          setAuthStatus('Введите email и пароль.');
          return;
        }
        const btn = $('#authSubmit');
        btn.disabled = true;
        btn.textContent = 'Входим…';
        try {
          const resp = await postJson('/auth/login', { email, password });
          if (resp.error) {
            if (resp._status === 401) {
              setAuthStatus('Неверный email или пароль.');
            } else if (resp._status === 403 && resp.error === 'email_not_verified') {
              setAuthStatus('Email не подтверждён. Проверьте почту или перейдите на /verify.', 'warn');
            } else {
              setAuthStatus('Ошибка: ' + resp.error);
            }
            return;
          }
          saveUser({
            email: resp.email || email,
            id: resp.id || resp.user_id || null,
            gtc_user_id: resp.gtc_user_id || resp.gtcUserId || null,
            jwt: resp.jwt || resp.token || null,
            full_name: resp.full_name || resp.name || null
          });
        } catch (error) {
          setAuthStatus('Ошибка сети: ' + error.message);
        } finally {
          btn.disabled = false;
          btn.textContent = 'Войти и получить gtc_user_id';
        }
      });

      googleBtn?.addEventListener('click', () => {
        window.location.href = '/auth/google/?next=%2Fchat';
      });

      otpRequestBtn?.addEventListener('click', async () => {
        if (!otpEmailInput) return;
        const email = otpEmailInput.value.trim().toLowerCase();
        if (!email) {
          setOtpStatus('Введите email для отправки кода.');
          return;
        }
        otpRequestBtn.disabled = true;
        setOtpStatus('Отправляем код…');
        try {
          const resp = await postJson('/auth/otp/request', { email });
          if (resp.error) {
            setOtpStatus('Ошибка: ' + (resp.error || 'unknown'), 'err');
            return;
          }
          otpState.email = email;
          otpState.requested = true;
          if (otpCodeInput) otpCodeInput.disabled = false;
          otpVerifyBtn.disabled = false;
          setOtpStatus('Код отправлен. Проверьте почту и введите его ниже.', 'ok');
        } catch (error) {
          setOtpStatus('Ошибка сети: ' + error.message, 'err');
        } finally {
          otpRequestBtn.disabled = false;
        }
      });

      otpVerifyBtn?.addEventListener('click', async () => {
        if (!otpState.requested) {
          setOtpStatus('Сначала запросите код.', 'warn');
          return;
        }
        const code = (otpCodeInput?.value || '').trim();
        if (code.length < 4) {
          setOtpStatus('Введите код из письма.', 'warn');
          return;
        }
        otpVerifyBtn.disabled = true;
        setOtpStatus('Подтверждаем код…');
        try {
          const resp = await postJson('/auth/otp/verify', { email: otpState.email, code });
          if (resp.error) {
            setOtpStatus('Ошибка: ' + resp.error, 'err');
            return;
          }
          saveUser({
            email: resp.email || otpState.email,
            id: resp.id || resp.user_id || null,
            gtc_user_id: resp.gtc_user_id || resp.gtcUserId || null,
            jwt: resp.jwt || resp.token || null,
            full_name: resp.full_name || resp.name || null
          });
          if (otpCodeInput) {
            otpCodeInput.value = '';
            otpCodeInput.disabled = true;
          }
          otpVerifyBtn.disabled = true;
          otpState.requested = false;
          setOtpStatus('Готово! Вы авторизованы через OTP.', 'ok');
        } catch (error) {
          setOtpStatus('Ошибка сети: ' + error.message, 'err');
        } finally {
          if (otpState.requested) {
            otpVerifyBtn.disabled = false;
          }
        }
      });

      logoutBtn.addEventListener('click', () => {
        state.user = null;
        localStorage.removeItem(storageKeys.user);
        setChatStatus('Вы вышли из аккаунта.', 'warn');
        updateAuthUI();
      });

      copyIdBtn.addEventListener('click', async () => {
        if (!state.user?.gtc_user_id) return;
        try {
          await navigator.clipboard.writeText(String(state.user.gtc_user_id));
          setChatStatus('gtc_user_id скопирован в буфер обмена.', 'ok');
        } catch {
          setChatStatus('Не удалось скопировать. Скопируйте вручную.', 'err');
        }
      });

      refreshProfileBtn.addEventListener('click', async () => {
        if (!state.user) return;
        setChatStatus('Обновление профиля…', 'warn');
        try {
          const resp = await fetch('/auth/profile', { credentials: 'include' });
          const data = await resp.json().catch(() => ({}));
          if (resp.ok && data?.gtc_user_id) {
            saveUser({
              email: data.email || state.user.email,
              id: data.id || data.user_id || state.user.id,
              gtc_user_id: data.gtc_user_id,
              jwt: data.jwt || state.user.jwt || null
            });
            setChatStatus('Профиль обновлён.', 'ok');
          } else {
            setChatStatus('Не удалось обновить профиль.', 'err');
          }
        } catch (error) {
          setChatStatus('Ошибка сети: ' + error.message, 'err');
        }
      });

      resetSessionBtn.addEventListener('click', () => {
        resetSession();
      });

      clearChatBtn.addEventListener('click', () => {
        clearHistory();
        pushSystem('Локальная история очищена.');
      });

      chatForm.addEventListener('submit', async (event) => {
        event.preventDefault();
        if (!state.user?.gtc_user_id) {
          setChatStatus('Сначала войдите, чтобы получить gtc_user_id.', 'warn');
          return;
        }
        const message = chatInput.value.trim();
        if (!message) return;
        await sendMessage(message);
      });

      chatInput.addEventListener('keydown', (event) => {
        if (event.key === 'Enter' && !event.shiftKey) {
          event.preventDefault();
          chatForm.dispatchEvent(new Event('submit'));
        }
      });

      async function sendMessage(text) {
        if (state.sending) return;
        state.sending = true;
        sendBtn.disabled = true;
        sendBtn.textContent = 'Отправка…';
        setChatStatus('Отправляем запрос в n8n…', 'warn');
        pushMessage('user', text, {});
        chatInput.value = '';
        try {
          const payload = buildPayload(text);
          const response = await fetch('/webhook/web-chat', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
          });
          const data = await response.json().catch(() => ({ status: 'error', detail: 'bad_json' }));
          handleAgentResponse(data, response.status);
        } catch (error) {
          pushMessage('system', 'Ошибка сети: ' + error.message, {});
          setChatStatus('Ошибка сети.', 'err');
        } finally {
          state.sending = false;
          sendBtn.disabled = false;
          sendBtn.textContent = 'Отправить';
        }
      }

      function buildPayload(message) {
        const timezone = Intl.DateTimeFormat().resolvedOptions().timeZone;
        const locale = navigator.language || 'en';
        const jwt = state.user?.jwt || localStorage.getItem('jwt') || '';
        return {
          channel: 'web',
          message,
          session_id: state.sessionId,
          jwt,
          client: {
            gtc_user_id: state.user?.gtc_user_id ?? null,
            user_id: state.user?.id ?? null,
            email: state.user?.email ?? null,
            jwt,
            locale,
            timezone,
            metadata: {
              full_name: state.user?.full_name || null
            }
          },
          metadata: {
            page: location.pathname,
            user_agent: navigator.userAgent,
            language: locale
          }
        };
      }

      function handleAgentResponse(data, httpStatus) {
        if (httpStatus === 401 || data?.status === 'error' && data?.code === 'unauthorized') {
          pushSystem('Доступ запрещён. Пожалуйста, оплатите подписку или войдите заново.');
          setChatStatus('Неавторизовано. Попробуйте войти снова.', 'err');
          state.user = null;
          localStorage.removeItem(storageKeys.user);
          updateAuthUI();
          return;
        }
        if (httpStatus === 402 || data?.status === 'payment_required') {
          pushSystem('Нужна активная подписка. Перейдите на страницу оплаты, используя ваш gtc_user_id.');
          setChatStatus('Подписка не активна. Оплатите и попробуйте снова.', 'warn');
          return;
        }
        if (httpStatus >= 500 || data?.status === 'error') {
          setChatStatus('Ошибка сервера, повторите позже.', 'err');
          return;
        }
        const reply = data?.reply || data?.output || 'Нет ответа';
        pushMessage('bot', reply, { trace_id: data?.trace_id, stage: data?.stage });
        setChatStatus('Готово (trace ' + (data?.trace_id || '—') + ')', 'ok');
      }
    })();
  </script>
</body>
</html>
